  section:     'produktsiia',
  title:       'Щит димовидалення на замовлення — Київ та область | elektroschit.com.ua',
  description: 'Виготовляємо щити димовидалення, підпору повітря та керування протипожежними клапанами. Робота за схемами проєктної організації або розробка з нуля. Гарантія 12 міс. Київ та вся Україна.',
  canonical:   `${SITE_CANONICAL}/posluhy-ta-produktsiia/dymovydalennia/`,
  crumbs: [
    { label: 'Головна',   href: '/' },
    { label: 'Продукція', href: '/posluhy-ta-produktsiia/' },
    { label: 'Щити димовидалення' },
  ],
};

const hero = {
  tag:    'Виготовлення · Київ та область',
  h1:     'Виготовлення щитів димовидалення на замовлення',
  lead:   'Виготовляємо щити для систем протидимного захисту будівель: димовидалення, підпір повітря, керування протипожежними клапанами. Робота за схемами проєктної організації або розробка схеми з нуля. Київ, Київська область та вся Україна.',
  badges: [
    '<strong>від 1</strong> вентилятора і більше',
    '<strong>від 2 тижнів</strong> — виготовлення',
    '<strong>12 міс.</strong> — гарантія',
    '<strong>25 років</strong> — досвід',
  ],
  collage: [
    { src: '/images/dymovydalennia/dymovydalennia-shchmu-3-zony-fasad-kyiv-2026-06-c1.jpg',     alt: 'Щит димовидалення ЩМУ — фасад, 3 зони керування' },
    { src: '/images/dymovydalennia/dymovydalennia-shchmu-4-zony-fasad-kyiv-2026-06-c2.jpg',     alt: 'Щит керування димовидаленням — 4 зони, ДВ1, КДВ1, ПП1, ПП2' },
    { src: '/images/dymovydalennia/dymovydalennia-vnutrishniy-montazh-avtomaty-kyiv-2026-06-c3.jpg', alt: 'Внутрішній монтаж щита димовидалення — автомати ETI, контактори' },
    { src: '/images/dymovydalennia/dymovydalennia-shkpp-pidpir-fasad-kyiv-2026-06-c4.jpg',     alt: 'Шафа ШКПП — щит керування вентилятором підпору повітря' },
  ],
};

const gallery = {
  h2: 'Збірка щитів димовидалення — фото з нашого виробництва',
  items: [
    { src: '/images/dymovydalennia/dymovydalennia-shchmu-3-zony-zahalnyi-vyhlyad-kyiv-2026-06-01.jpg', alt: 'Щит димовидалення ЩМУ — загальний вигляд, 3 зони',             caption: 'Щит ЩМУ ДВ1+КДВ1+ПП1 — фасад, 3 зони керування, автоматичний та ручний режими', large: true },
    { src: '/images/dymovydalennia/dymovydalennia-shchmu-4-zony-fasad-kyiv-2026-06-c2.jpg',           alt: 'Щит димовидалення — фасад 4 зони',                          caption: 'Щит ЩМУ — 4 зони (ДВ1, КДВ1, ПП1, ПП2), фасад з перемикачами та сигнальними лампами' },
    { src: '/images/dymovydalennia/dymovydalennia-shmu-fasad-odyn-ventylator-kyiv-2026-06-03.jpg',   alt: 'Шафа ШМУ — один вентилятор, пуск/стоп',                    caption: 'Шафа ШМУ — керування одним вентилятором, режим РУЧ–0–АВТ, кнопки пуск/стоп' },
    { src: '/images/dymovydalennia/dymovydalennia-vnutrishniy-montazh-avtomaty-kyiv-2026-06-c3.jpg', alt: 'Внутрішній монтаж щита — автомати та контактори ETI',        caption: 'Внутрішній монтаж — автомати ETI QF1–QF4, контактори KM1–KM3, реле KV, клеми' },
    { src: '/images/dymovydalennia/dymovydalennia-vnutrishniy-kontaktor-eti-rele-kv-kyiv-2026-06-05.jpg', alt: 'Контактор ETI та реле KV у щиті димовидалення',      caption: 'Контактор ETI KM1, автомати QF1/QF2, реле контролю напруги KV — акуратна укладка кабелів' },
    { src: '/images/dymovydalennia/dymovydalennia-kontaktory-eti-km1-km4-kyiv-2026-06-02.jpg',       alt: '4 контактори ETI у щиті димовидалення',                    caption: '4 контактори ETI KM1–KM4 на DIN-рейці — щит керування клапанами димовидалення' },
    { src: '/images/dymovydalennia/dymovydalennia-shkpp-vidkrytyy-montazh-dvertsya-kyiv-2026-06-07.jpg', alt: 'Щит ШКПП відкритий — монтаж панелі та дверцят',       caption: 'Шафа ШКПП — щит підпору повітря, відкритий корпус: монтажна панель та монтаж дверей' },
    { src: '/images/dymovydalennia/dymovydalennia-shkpp-vnutrishniy-rele-k1-k4-kyiv-2026-06-08.jpg', alt: 'Внутрішній монтаж ШКПП — реле та контактор',               caption: 'Внутрішній монтаж ШКПП — реле K1–K4, контактор KM1, клемні колодки' },
  ],
};

const objects = {
  label: 'Застосування',
  h2:    'Де застосовуються щити димовидалення',
  lead:  'Щити димовидалення, підпору повітря та керування протипожежними клапанами — окремий клас обладнання протипожежного розділу проєкту.',
  cards: [
    { num: '01', title: 'Складські комплекси та логістичні термінали', text: 'Димовидалення через покрівлю або примусова витяжка по зонах при пожежі.' },
    { num: '02', title: 'Торгові та торгово-розважальні центри',       text: 'Зонування систем димовидалення, підпір повітря в сходових клітинах та атріумах.' },
    { num: '03', title: 'Виробничі підприємства',                      text: 'Аварійна витяжка диму з виробничих цехів, керування клапанами по секціях.' },
    { num: '04', title: 'Офісні та бізнес-центри',                     text: 'Підпір повітря в ліфтових шахтах та тамбур-шлюзах, автоматичне спрацювання від АУПС.' },
    { num: '05', title: 'Підрядні організації',                        text: 'Електромонтажні компанії, які ведуть монтаж систем протидимного захисту і потребують щит за схемою замовника.' },
  ],
};

const specs = {
  h2:   'Технічні характеристики щита димовидалення',
  rows: [
    { label: 'Напруга живлення',                    value: '380В / 50Гц або 220В — за проєктом' },
    { label: 'Кількість вентиляторів',              value: 'від 1 і більше — за ТЗ' },
    { label: 'Кількість клапанів',                  value: 'від 1 і більше — за ТЗ' },
    { label: 'Керування',                           value: 'Автоматичне (від АУПС) + ручне' },
    { label: 'Зонування',                           value: 'За проєктом або ТЗ замовника' },
    { label: 'Диспетчеризація',                     value: 'За вимогою замовника' },
    { label: 'Виготовлення за схемами замовника',   value: 'Так' },
    { label: 'Розробка схем під ТЗ',               value: 'Так' },
    { label: 'Гарантія',                            value: '12 місяців' },
    { label: 'Терміни виготовлення',                value: 'від 2 тижнів' },
    { label: 'Доставка',                            value: 'Київ, Київська область, вся Україна' },
  ],
};

const brands = {
  main: ['ETI', 'Hager', 'Schneider Electric', 'Eaton'],
  eco:  ['E-Next', 'Asko', 'Chint'],
};

const steps = {
  h2:    '5 кроків від ТЗ до готового щита',
  items: [
    { title: 'Технічне завдання',        text: 'Надсилаєте ТЗ, схему або описуєте задачу. Приймаємо PDF, DWG, фото, усний опис.' },
    { title: 'Розрахунок та схема',      text: 'Розробляємо або перевіряємо схему, узгоджуємо вартість та строки. Відповідаємо за 1–2 дні.' },
    { title: 'Оплата',                   text: 'Після оплати виріб ставиться у виробництво.' },
    { title: 'Збірка та перевірка',      text: 'Збираємо у Києві. Маркуємо, перевіряємо кожен щит перед відправкою.' },
    { title: 'Передача з документацією', text: 'Доставка по Києву та Київській обл. або Нова Пошта. Паспорт виробу та схема — у щиті.' },
  ],
};

const why = {
  h2:    'Чому замовляють у нас',
  cards: [
    { title: 'Досвід з 1999 року',                text: '25+ років виготовлення щитів для промислових та комерційних об\'єктів.' },
    { title: 'Робота за проєктною документацією', text: 'Приймаємо схеми від будь-якої проєктної організації та збираємо точно за ними.' },
    { title: 'Розробляємо схеми самостійно',      text: 'Якщо немає проєкту — надішліть ТЗ або опис задачі. Ми самі розробимо схему та узгодимо з вами.' },
    { title: 'Тестування перед відправкою',       text: 'Кожен щит перевіряється до передачі замовнику. Паспорт виробу — з кожним щитом.' },
    { title: 'Доставка по всій Україні',          text: 'По Києву та Київській обл. — власним транспортом. По Україні — Новою Поштою.' },
    { title: 'Гарантія 12 місяців',              text: 'На кожен виготовлений щит — письмове гарантійне зобов\'язання.' },
  ],
};

const faq = {
  sectionTitle: 'Питання про виготовлення щитів димовидалення',
  items: [
    { q: 'Що робити, якщо готової схеми немає?',                          a: 'Надішліть опис задачі — які споживачі, яке навантаження, які режими роботи. Розробимо принципову схему самостійно та узгодимо з вами перед початком виготовлення.' },
    { q: 'Чи можна надати свої компоненти для збірки?',                   a: 'Ні. Ми самостійно закуповуємо все обладнання відповідно до узгодженої специфікації і передаємо замовнику готовий виріб з гарантією. Це дозволяє нам відповідати за якість щита від початку до кінця.' },
    { q: 'Яку документацію ви передаєте разом зі щитом?',                 a: 'Паспорт виробу та принципову схему. Документи вкладаються безпосередньо у щит.' },
    { q: 'Чи потрібен ПЛК, чи достатньо релейної схеми?',                a: 'Залежить від задачі. Якщо зон і сигналів небагато — реалізуємо на релейній схемі: надійно і дешевше. Якщо логіка складна або зон багато — інтегруємо ПЛК. Завжди вибираємо рішення виходячи з доцільності.' },
    { q: 'Чи інтегрується щит з пожежною сигналізацією будь-якого виробника?', a: 'Так. Працюємо від сигналу будь-якої АУПС — як правило це нормально-відкритий або нормально-закритий контакт. Якщо проект передбачає інший тип сигналу — адаптуємо рішення до вимог проекту.' },
    { q: 'Чи можна керувати кількома зонами незалежно?',                  a: 'Так. Реалізуємо зональне керування будь-якою кількістю груп обладнання. Кожна зона спрацьовує незалежно — автоматично або вручну.' },
    { q: 'Чому термін виготовлення від 2 тижнів, а не від 1?',           a: 'Щити димовидалення — складніші вироби, ніж стандартні силові щити. Більше компонентів, детальне тестування логіки керування перед відправкою. Точний термін узгоджується після отримання ТЗ або схеми.' },
  ],
};
---
<ProductLayout
  {page}
  slug="dymovydalennia"
  {hero}
  {gallery}
  {objects}
  {specs}
  {brands}
  {steps}
  {why}
  {faq}
  contactTitle="Готові обговорити ваше замовлення — щит димовидалення"
>
  <!-- extra1: Які щити виготовляємо — білий фон -->
  <section slot="extra1" class="em-section">
    <span class="em-section-label">Продукція</span>
    <h2>Які щити димовидалення виготовляємо</h2>
    <p class="em-lead">Виготовляємо щити для обладнання димовидалення — на одну або кілька одиниць, відповідно до проєкту.</p>
    <div class="em-why-grid">
      <div class="em-why-card">
        <div class="em-why-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3>Щит димовидалення</h3>
        <p>Керування витяжними вентиляторами: автоматичний запуск від АУПС, ручне керування по зонах, сигналізація стану.</p>
      </div>
      <div class="em-why-card">
        <div class="em-why-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3>Щит підпору повітря</h3>
        <p>Керування припливними вентиляторами для сходових кліток, тамбур-шлюзів та ліфтових шахт.</p>
      </div>
      <div class="em-why-card">
        <div class="em-why-card-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
          </svg>
        </div>
        <h3>Щит керування протипожежними клапанами</h3>
        <p>Автоматичне відкриття або закриття клапанів за сигналом пожежної сигналізації, з індикацією положення.</p>
      </div>
    </div>
  </section>
</ProductLayout>
