---
import { PHONE, PHONE_DISPLAY, SITE_CANONICAL } from '../../config';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import AlsoMake from '../../components/AlsoMake.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import Lightbox from '../../components/Lightbox.astro';

const title = "Виготовлення конденсаторних установок КРМ на замовлення | elektroschit.com.ua";
const description = "Виготовляємо конденсаторні установки КРМ для компенсації реактивної потужності на замовлення. Від 25 кВАр. Гарантія 12 місяців. Київ, ETI, Schneider Electric.";

const faqItems = [
  {
    q: "Звідки взяти дані для розрахунку КРМ?",
    a: "Потрібні дані з рахунків за електроенергію: споживана активна потужність (кВт), реактивна потужність (кВАр) або поточний cos φ. Якщо рахунки недоступні — можна зробити вимірювання приладами або надати дані про основне обладнання на об'єкті: двигуни, трансформатори, їх потужність."
  },
  {
    q: "Які дані потрібні для замовлення КРМ?",
    a: "Для розрахунку достатньо двох параметрів: потужність трансформатора підстанції (кВА) та необхідна потужність компенсації (кВАр). Якщо ці дані невідомі — надішліть рахунки за електроенергію або опис об'єкта, розрахуємо самостійно."
  },
  {
    q: "Чи є різниця між КРМ з реактором і без?",
    a: "КРМ без реакторів підходить для більшості промислових об'єктів з лінійним навантаженням. КРМ з дросельними реакторами (антигармонічна версія) використовують там, де є нелінійне навантаження — частотні перетворювачі, джерела безперебійного живлення, зварювальне обладнання. Якщо не впевнені — уточніть склад навантаження при замовленні."
  },
  {
    q: "Скільки ступенів регулювання потрібно?",
    a: "Мінімум — 3–4 ступені, для плавного регулювання зазвичай достатньо 6–12 ступенів. Кількість ступенів впливає на плавність роботи та розмір щита. Оптимальний варіант підбираємо разом із замовником після аналізу характеру навантаження."
  },
  {
    q: "Чи можна встановити КРМ без відключення виробництва?",
    a: "Підключення КРМ виконується з боку вводу в ГРЩ або безпосередньо до шин трансформатора. Для підключення потрібне короткочасне відключення — зазвичай достатньо технологічної перерви або вихідного дня. Точний порядок підключення залежить від схеми електропостачання об'єкта."
  },
  {
    q: "Як швидко окупиться КРМ?",
    a: "Терміни окупності залежать від тарифу на реактивну потужність та розміру штрафних коефіцієнтів. На більшості промислових підприємств КРМ окупається за 6–18 місяців. Зниження рахунку за електроенергію помітне вже з першого місяця після підключення."
  },
  {
    q: "Яка гарантія та строки виготовлення?",
    a: "Гарантія — 12 місяців з моменту передачі. Строк виготовлення — від 2 тижнів, уточнюється при постановці у виготовлення залежно від потужності та кількості ступенів."
  },
];
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`${SITE_CANONICAL}/posluhy-ta-produktsiia/krm/`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@300;400;500;600;700&family=Manrope:wght@400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
  <link rel="stylesheet" href="/css/em-hrshch.css" />
</head>
<body>

<Header activePage="produktsiia" />

<Breadcrumbs current="КРМ — конденсаторні установки" />

<!-- HERO — зелений -->
<div class="em-hero-product">
  <div class="em-hero-product-inner">
    <div class="em-hero-product-text">
      <h1>Виготовлення конденсаторних установок КРМ на замовлення</h1>
      <p class="em-hero-product-lead">Компенсуємо реактивну потужність на промислових підприємствах — автоматичні конденсаторні установки від 25 кВАр на замовлення. Знижуємо рахунки за електроенергію та штрафні коефіцієнти. Гарантія 12 місяців.</p>
      <div class="em-hero-badges">
        <div class="em-badge"><strong>від 25 кВАр</strong> — потужність</div>
        <div class="em-badge"><strong>від 2 тижнів</strong> — виготовлення</div>
        <div class="em-badge"><strong>12 міс.</strong> — гарантія</div>
        <div class="em-badge"><strong>25 років</strong> — досвід</div>
      </div>
      <div class="em-hero-product-actions">
        <a href="#kontakty-blok" class="em-btn-primary">Замовити / Зв'язатися з нами</a>
      </div>
      <p class="em-hero-product-contact">Або зателефонуйте: <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></p>
    </div>
    <div class="em-hero-collage">
      <div class="em-hero-collage-item">
        <img src="/images/krm/krm-kondensatorna-ustanovka-povnyy-vyhlyad-kyiv-2026-06-c1.jpg"
             alt="КРМ — повний вигляд відкритого щита, конденсатори RTR та автоматика" loading="eager" />
      </div>
      <div class="em-hero-collage-item">
        <img src="/images/krm/krm-rehulyator-eti-pfc6-fasad-kyiv-2026-06-c2.jpg"
             alt="Фасад КРМ з двома регуляторами реактивної потужності ETI PFC 6" loading="eager" />
      </div>
      <div class="em-hero-collage-item">
        <img src="/images/krm/krm-rehulyator-eti-pfc12-fasad-kyiv-2026-06-c3.jpg"
             alt="Фасад конденсаторної установки КРМ з регулятором ETI PFC 12" loading="lazy" />
      </div>
      <div class="em-hero-collage-item">
        <img src="/images/krm/krm-vvid-rubilnyk-kontaktory-kondensatory-kyiv-2026-06-c4.jpg"
             alt="КРМ відкритий — вводний рубильник ETI, контактори, конденсаторні батареї" loading="lazy" />
      </div>
    </div>
  </div>
</div>

<!-- ГАЛЕРЕЯ — білий -->
<section class="em-section">
  <span class="em-section-label">Наші роботи</span>
  <h2>Виготовлення КРМ — фото з нашого виробництва</h2>
  <div class="em-product-gallery">
    <div class="em-gallery-item em-gallery-item-large"
         data-caption="КРМ відкритий — контактори, автоматика ETI, конденсатори у нижній секції"
         data-full="/images/krm/krm-montazh-kontaktory-kondensatory-eti-kyiv-2026-06-01.jpg">
      <img src="/images/krm/krm-montazh-kontaktory-kondensatory-eti-kyiv-2026-06-01.jpg"
           alt="КРМ відкритий — контактори ETI, автомати та конденсаторні батареї" width="900" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Контактори та однолінійна схема на внутрішній стороні дверцят"
         data-full="/images/krm/krm-kontaktory-skhema-na-dveri-kyiv-2026-06-02.jpg">
      <img src="/images/krm/krm-kontaktory-skhema-na-dveri-kyiv-2026-06-02.jpg"
           alt="Контактори КРМ та монтажна схема на двері щита" width="880" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Регулятори реактивної потужності ETI — крупним планом"
         data-full="/images/krm/krm-rehulyatory-eti-krupno-kyiv-2026-06-03.jpg">
      <img src="/images/krm/krm-rehulyatory-eti-krupno-kyiv-2026-06-03.jpg"
           alt="Регулятори реактивної потужності ETI у щиті КРМ" width="900" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Автомати ETI, контактори та конденсаторні батареї — погляд зверху"
         data-full="/images/krm/krm-avtomaty-kontaktory-kondensatory-pohlyad-zverhu-kyiv-2026-06-04.jpg">
      <img src="/images/krm/krm-avtomaty-kontaktory-kondensatory-pohlyad-zverhu-kyiv-2026-06-04.jpg"
           alt="Монтаж КРМ зверху — автоматика ETI та конденсатори" width="900" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Конденсаторні батареї ETI LPC 40 кВАр — підготовка до монтажу"
         data-full="/images/krm/krm-kondensatory-eti-lpc-40-kvar-stellazh-kyiv-2026-06-05.jpg">
      <img src="/images/krm/krm-kondensatory-eti-lpc-40-kvar-stellazh-kyiv-2026-06-05.jpg"
           alt="Конденсатори ETI LPC 40 кВАр для конденсаторної установки КРМ" width="900" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Вводні рубильники ETI LA3 та ряди захисних автоматів"
         data-full="/images/krm/krm-vvodni-rubilnyky-eti-la3-avtomaty-kyiv-2026-06-06.jpg">
      <img src="/images/krm/krm-vvodni-rubilnyky-eti-la3-avtomaty-kyiv-2026-06-06.jpg"
           alt="Вводні рубильники ETI LA3 у конденсаторній установці КРМ" width="900" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Монтаж збоку — контактори та конденсаторні батареї ETI"
         data-full="/images/krm/krm-montazh-zboku-kontaktory-kondensatory-kyiv-2026-06-07.jpg">
      <img src="/images/krm/krm-montazh-zboku-kontaktory-kondensatory-kyiv-2026-06-07.jpg"
           alt="Вид збоку на монтаж КРМ — контактори та конденсатори" width="675" height="1200" loading="lazy" />
    </div>
    <div class="em-gallery-item"
         data-caption="Шафа ККУ з регуляторами NEO RPC-12 — готовий виріб"
         data-full="/images/krm/krm-shafa-kku-rehulyatory-rpc12-kyiv-2026-06-08.jpg">
      <img src="/images/krm/krm-shafa-kku-rehulyatory-rpc12-kyiv-2026-06-08.jpg"
           alt="Готова конденсаторна установка КРМ з регуляторами NEO RPC-12" width="900" height="1200" loading="lazy" />
    </div>
  </div>
  <div class="em-gallery-cta">
    <a href="/vykonani-roboty/" class="em-btn-primary">Переглянути роботи →</a>
  </div>
</section>

<!-- ПРО ПРОДУКТ — зелений -->
<div class="em-section-alt">
  <div class="em-section-alt-inner">
    <span class="em-section-label">Про продукт</span>
    <h2>Що таке КРМ і навіщо він потрібен</h2>
    <p class="em-lead">Конденсаторна установка КРМ компенсує реактивну потужність у мережі — підвищує коефіцієнт потужності cos&nbsp;φ до нормативного рівня та знижує штрафні нарахування від енергопостачальника.</p>
    <div class="em-objects-grid" style="margin-top: 8px;">
      <div class="em-object-card">
        <div class="em-object-num">cos φ</div>
        <h3>Підвищення cos&nbsp;φ до 0,95</h3>
        <p>Автоматичне регулювання підтримує cos&nbsp;φ у нормативному діапазоні — штрафні коефіцієнти зникають вже з першого місяця.</p>
      </div>
      <div class="em-object-card">
        <div class="em-object-num">↓A</div>
        <h3>Зниження струму в мережі</h3>
        <p>Зменшується струм у кабелях і трансформаторі — знижуються втрати, зростає ресурс обладнання та пропускна здатність мережі.</p>
      </div>
      <div class="em-object-card">
        <div class="em-object-num">Auto</div>
        <h3>Автоматичне регулювання</h3>
        <p>Регулятор підключає ступені конденсаторних батарей без участі оператора, відповідно до поточного навантаження.</p>
      </div>
    </div>
  </div>
</div>

<!-- ДЕ ЗАСТОСОВУЄТЬСЯ — білий -->
<section class="em-section">
  <span class="em-section-label">Застосування</span>
  <h2>КРМ — для яких об'єктів</h2>
  <p class="em-lead">Конденсаторні установки встановлюють там, де є індуктивне навантаження та штрафні нарахування за реактивну потужність.</p>
  <div class="em-objects-grid">
    <div class="em-object-card">
      <div class="em-object-num">01</div>
      <h3>Промислові підприємства</h3>
      <p>Заводи, цехи, виробничі лінії з електродвигунами, зварювальним та іншим індуктивним обладнанням.</p>
    </div>
    <div class="em-object-card">
      <div class="em-object-num">02</div>
      <h3>Агропромислові об'єкти</h3>
      <p>Зернотоки, елеватори, насосні станції, зрошувальні системи — де значна частка навантаження є асинхронними двигунами.</p>
    </div>
    <div class="em-object-card">
      <div class="em-object-num">03</div>
      <h3>Торгово-складські комплекси</h3>
      <p>Великі об'єкти з холодильним та кліматичним обладнанням, де cos&nbsp;φ знижується нижче нормативу.</p>
    </div>
    <div class="em-object-card">
      <div class="em-object-num">04</div>
      <h3>Насосні та компресорні станції</h3>
      <p>Об'єкти водопостачання та газопостачання з постійним навантаженням від потужних електродвигунів.</p>
    </div>
    <div class="em-object-card">
      <div class="em-object-num">05</div>
      <h3>Підрядні організації</h3>
      <p>Електромонтажні компанії, які виконують реконструкцію або нове будівництво і потребують готову КРМ за проєктом.</p>
    </div>
  </div>
</section>

<!-- ЩО ПОТРІБНО ДЛЯ ЗАМОВЛЕННЯ — зелений -->
<div class="em-section-alt">
  <div class="em-section-alt-inner">
    <span class="em-section-label">Як замовити</span>
    <h2>Що потрібно для розрахунку КРМ</h2>
    <p class="em-lead">Для розрахунку конденсаторної установки достатньо двох параметрів — решту визначимо самостійно.</p>
    <div class="em-objects-grid" style="margin-top: 8px;">
      <div class="em-object-card">
        <div class="em-object-num">01</div>
        <h3>Потужність трансформатора</h3>
        <p>Номінальна потужність трансформаторної підстанції (кВА) — зазначена на паспортній табличці трансформатора або в документах на ТП.</p>
      </div>
      <div class="em-object-card">
        <div class="em-object-num">02</div>
        <h3>Необхідна компенсація</h3>
        <p>Потужність компенсації у кВАр — з проєктної документації або розраховується на підставі рахунків за електроенергію.</p>
      </div>
      <div class="em-object-card">
        <div class="em-object-num">03</div>
        <h3>Немає даних — не проблема</h3>
        <p>Надішліть рахунок за електроенергію або опис основного обладнання — розрахуємо потрібну потужність КРМ самостійно.</p>
      </div>
    </div>
    <div style="margin-top: 28px;">
      <a href="#kontakty-blok" class="em-btn-primary">Надіслати запит на розрахунок</a>
    </div>
  </div>
</div>

<!-- ЩО МИ ВИГОТОВЛЯЄМО — білий -->
<section class="em-section">
  <span class="em-section-label">Склад установки</span>
  <h2>Що входить до складу КРМ</h2>
  <p class="em-lead">Виготовляємо регульовані конденсаторні установки з автоматичним регулятором — повністю готові до підключення.</p>
  <div class="em-why-grid">
    <div class="em-why-card">
      <h3>Вводний вимикач або рубильник</h3>
      <p>Забезпечує безпечне підключення та відключення КРМ від мережі. Вибирається залежно від загальної потужності установки.</p>
    </div>
    <div class="em-why-card">
      <h3>Регулятор реактивної потужності</h3>
      <p>Автоматично вимірює cos&nbsp;φ та керує підключенням ступенів. Використовуємо ETI PFC, NEO RPC та аналоги під запит.</p>
    </div>
    <div class="em-why-card">
      <h3>Конденсаторні батареї</h3>
      <p>Трифазні конденсатори ETI LPC або аналоги. Потужність кожного ступеня та кількість ступенів — за розрахунком.</p>
    </div>
    <div class="em-why-card">
      <h3>Контактори для комутації</h3>
      <p>Силові контактори з конденсаторним гасінням дуги для підключення кожного ступеня. ETI, Schneider або аналоги.</p>
    </div>
    <div class="em-why-card">
      <h3>Захисні автомати ступенів</h3>
      <p>Захищають кожен ступінь конденсаторної батареї від перевантажень та коротких замикань.</p>
    </div>
    <div class="em-why-card">
      <h3>Однолінійна схема</h3>
      <p>Виконується та вкладається всередину щита. Передається замовнику разом із паспортом виробу.</p>
    </div>
  </div>
</section>

<!-- ХАРАКТЕРИСТИКИ — зелений -->
<div class="em-section-alt">
  <div class="em-section-alt-inner">
    <span class="em-section-label">Характеристики</span>
    <h2>Технічні характеристики КРМ</h2>
    <table class="em-specs-table">
      <tbody>
        <tr><td class="em-specs-label">Потужність компенсації</td><td class="em-specs-value">від 25 кВАр — за розрахунком</td></tr>
        <tr><td class="em-specs-label">Кількість ступенів</td><td class="em-specs-value">від 3 до 12 ступенів і більше</td></tr>
        <tr><td class="em-specs-label">Регулятор</td><td class="em-specs-value">ETI PFC 6/12, NEO RPC-12 або аналоги</td></tr>
        <tr><td class="em-specs-label">Конденсаторні батареї</td><td class="em-specs-value">ETI LPC або аналоги під запит</td></tr>
        <tr><td class="em-specs-label">Напруга мережі</td><td class="em-specs-value">400 В, 50 Гц</td></tr>
        <tr><td class="em-specs-label">Виконання</td><td class="em-specs-value">Напільний або настінний металевий корпус</td></tr>
        <tr><td class="em-specs-label">Однолінійна схема</td><td class="em-specs-value">Виконується та додається у щит</td></tr>
        <tr><td class="em-specs-label">Термін виготовлення</td><td class="em-specs-value">Від 2 тижнів, узгоджується при постановці</td></tr>
        <tr><td class="em-specs-label">Гарантія</td><td class="em-specs-value">12 місяців</td></tr>
        <tr><td class="em-specs-label">Доставка</td><td class="em-specs-value">Київ, Київська область, вся Україна</td></tr>
      </tbody>
    </table>
  </div>
</div>

<!-- КОМПОНЕНТИ — білий -->
<section class="em-section">
  <span class="em-section-label">Компоненти</span>
  <h2>Компоненти та виробники</h2>
  <p class="em-lead">Підбираємо під бюджет та наявність. Конкретний бренд узгоджується при прийомі замовлення.</p>
  <div class="em-brands">
    <div class="em-brands-group">
      <div class="em-brands-group-label">Основні бренди</div>
      <div class="em-brands-row">
        <div class="em-brand-pill">ETI</div>
        <div class="em-brand-pill">Schneider Electric</div>
        <div class="em-brand-pill">Eaton</div>
        <div class="em-brand-pill">Hager</div>
      </div>
