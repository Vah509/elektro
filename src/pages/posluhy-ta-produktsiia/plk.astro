---
import { SITE_CANONICAL } from '../../config';
import ProductLayout from '../../layouts/ProductLayout.astro';

const page = {
  lang:        'uk' as const,
  altUrl:      '/ru/posluhy-ta-produktsiia/plk/',
  section:     'posluhy',
  title:       'Програмування ПЛК на замовлення — Київ та область | elektroschit.com.ua',
  description: 'Програмування логічних контролерів під ваше технічне завдання. Керування двигунами, насосами, вентиляцією, технологічними процесами. Окремо або разом зі збіркою щита. Київ та вся Україна.',
  canonical:   `${SITE_CANONICAL}/posluhy-ta-produktsiia/plk/`,
  crumbs: [
    { label: 'Головна',  href: '/' },
    { label: 'Послуги', href: '/posluhy-ta-produktsiia/' },
    { label: 'Програмування ПЛК' },
  ],
};

const hero = {
  tag:    'Послуга · Київ та область',
  h1:     'Програмування ПЛК на замовлення',
  lead:   'Розробляємо програми для логічних контролерів під конкретне технічне завдання. Керування двигунами, насосами, вентиляцією, технологічними процесами — від простої послідовності пуску до алгоритмів керування кількома вузлами. Окремо або разом зі збіркою щита. Київ, Київська область та вся Україна.',
  badges: [
    '<strong>ПЛК + щит</strong> або тільки програма',
    '<strong>від 1 тижня</strong> — розробка',
    '<strong>12 міс.</strong> — гарантія',
    '<strong>25 років</strong> — досвід',
  ],
  collage: [
    { src: '/images/plk/plk-oven-flexi-s2-a1-releini-moduli-kyiv-2026-06-c1.jpg',  alt: 'Щит керування з ПЛК ОВЕН Flexi S2-A1 та реле ETI — загальний вигляд монтажу' },
    { src: '/images/plk/plk-schneider-zelio-sr3-krupno-kyiv-2026-06-c2.jpg',       alt: 'Контролер Schneider Electric Zelio SR3 B261BD — кліщовий монтаж на DIN-рейці' },
    { src: '/images/plk/plk-oven-pr100-schebt-releini-moduli-kyiv-2026-06-c3.jpg', alt: 'ПЛК ОВЕН ПР100 зі з\'єднувальним блоком ETI та групою реле — щит керування' },
    { src: '/images/plk/plk-aqteck-pr200-schyt-compact-kyiv-2026-06-c4.jpg',       alt: 'Щит керування з ПЛК AQteck ПР200 — компактне виконання, живлення Mean Well' },
  ],
};

const gallery = {
  h2: 'Щити з ПЛК — фото з нашого виробництва',
  items: [
    { src: '/images/plk/plk-schyt-oven-velykyi-releini-blok-kyiv-2026-06-01.jpg',      alt: 'Великий щит керування з ПЛК ОВЕН та блоком реле',                    caption: 'Великий щит керування з ПЛК ОВЕН та блоком реле — загальний вигляд відчиненого щита', large: true },
    { src: '/images/plk/plk-eaton-easy-schyt-keruvannia-kyiv-2026-06-02.jpg',           alt: 'Щит керування з контролером Eaton Easy — автомати ETI, мягкі пускачі WEG SSW-07', caption: 'Щит з Eaton Easy та мягкими пускачами WEG SSW-07 — керування групою двигунів' },
    { src: '/images/plk/plk-oven-flexi-s2-a1-krupno-kyiv-2026-06-03.jpg',              alt: 'ПЛК ОВЕН Flexi S2-A1 крупним планом — підключені входи виходи, маркування', caption: 'ОВЕН Flexi S2-A1 крупним планом — підключені клеми, маркування входів та виходів' },
    { src: '/images/plk/plk-oven-pr100-robota-indykatory-kyiv-2026-06-04.jpg',          alt: 'ПЛК ОВЕН ПР100 крупно — індикатори DI AI DO в режимі роботи',           caption: 'ОВЕН ПР100 — індикатори стану DI, AI, DO в режимі роботи програми' },
    { src: '/images/plk/plk-schneider-zelio-schyt-krupno-kyiv-2026-06-05.jpg',         alt: 'Schneider Electric Zelio Logic у щиті — реле ETI, клеми, маркування',   caption: 'Schneider Electric Zelio Logic у щиті: реле ETI, акуратне маркування клем' },
    { src: '/images/plk/plk-schyt-zelio-kontaktory-lytseva-kyiv-2026-06-06.jpg',       alt: 'Щит керування з Zelio та контакторами ETI — лицева панель з індикацією', caption: 'Щит з Zelio та контакторами ETI — чотири ряди DIN-рейок, акуратний монтаж' },
    { src: '/images/plk/plk-litseva-panel-shchyt-shuhnk-kyiv-2026-06-07.jpg',          alt: 'Лицева панель щита керування — кнопки пуску зупинки з підписами програм', caption: 'Лицева панель щита ШУНК з підписаними кнопками — ручний та автоматичний режими' },
    { src: '/images/plk/plk-schyt-m-puskateli-soft-starter-kyiv-2026-06-08.jpg',       alt: 'Щит керування двигунами — чотири мягкі пускачі WEG та автомати ETI',    caption: 'Щит з чотирма мягкими пускачами WEG SSW-07 та автоматами ETI — керування двигунами' },
  ],
};

const objects = {
  label: 'Напрямки',
  h2:    'Що програмуємо',
  lead:  'Беремося за задачі малої та середньої складності: автоматизацію окремого процесу, цеху, невеликої виробничої лінії. Не автоматизуємо великі заводські комплекси — працюємо там, де потрібне точне і надійне рішення під конкретну задачу.',
  cards: [
    { num: '01', title: 'Керування електродвигунами', text: 'Прямий пуск, реверс, зірка-трикутник, почергові запуски за сценарієм.' },
    { num: '02', title: 'Насосні станції',            text: 'Керування по рівню або тиску, черговість насосів, захисти.' },
    { num: '03', title: 'Вентиляція та кліматика',    text: 'Пуск/зупинка за датчиком, блокування, аварійна сигналізація.' },
    { num: '04', title: 'Протипожежна автоматика',    text: 'Димовидалення, підпір повітря, керування клапанами та приводами.' },
    { num: '05', title: 'Технологічні процеси',       text: 'Керування клапанами, двигунами та виконавчими механізмами за заданим сценарієм.' },
    { num: '06', title: 'Агровиробництво',            text: 'Автоматизація вентиляції, годівлі, поливу на фермах і тепличних господарствах.' },
  ],
};

const specs = {
  h2:   'З якими контролерами працюємо',
  rows: [
    { label: 'Siemens LOGO!',                  value: 'Компактні задачі: керування 1–3 вузлами, прості алгоритми, таймери, лічильники' },
    { label: 'Schneider Electric Zelio Logic', value: 'Аналог LOGO! — застосовуємо залежно від наявності та побажань замовника' },
    { label: 'Eaton Easy (Easy-E4)',           value: 'Компактні рішення для невеликих установок' },
    { label: 'ОВЕН',                           value: 'Вітчизняний виробник, широко застосовується на українських підприємствах' },
  ],
};

// plk не має блоку Компоненти — передаємо undefined
const steps = {
  h2:    '5 кроків від ТЗ до готового рішення',
  items: [
    { title: 'Технічне завдання',      text: 'Надсилаєте опис задачі або схему. Приймаємо PDF, DWG, фото, усний опис — будь-який зручний формат.' },
    { title: 'Розробка алгоритму',     text: 'Розробляємо або перевіряємо алгоритм роботи, узгоджуємо вартість та строки. Відповідаємо за 1–2 дні.' },
    { title: 'Оплата',                 text: 'Після оплати виріб або послуга ставиться у виконання.' },
    { title: 'Збірка та програмування', text: 'Збираємо щит, встановлюємо контролер, пишемо та завантажуємо програму.' },
    { title: 'Тестування та передача', text: 'Перевіряємо роботу програми перед передачею. Паспорт виробу та схема — у щиті.' },
  ],
};

const why = {
  h2:    'Чому замовляють у нас',
  cards: [
    { title: 'Досвід з 1999 року',                text: '25+ років виготовлення щитів та програмування контролерів для промислових та комерційних об\'єктів.' },
    { title: 'Розробляємо алгоритм за описом',    text: 'Не потрібна готова схема — опишіть задачу словами, ми розробимо алгоритм і узгодимо з вами перед початком.' },
    { title: 'Робота за проєктною документацією', text: 'Приймаємо схеми від будь-якої проєктної організації та програмуємо точно за ними.' },
    { title: 'Тестування перед відправкою',       text: 'Кожна програма перевіряється до передачі замовнику. Паспорт виробу — з кожним щитом.' },
    { title: 'Доставка по всій Україні',          text: 'По Києву та Київській обл. — власним транспортом. По Україні — Новою Поштою.' },
    { title: 'Гарантія 12 місяців',              text: 'На кожен виготовлений щит та розроблену програму — письмове гарантійне зобов\'язання.' },
  ],
};

const faq = {
  sectionTitle: 'Питання про програмування ПЛК',
  items: [
    { q: 'Що робити, якщо готової схеми немає?',          a: 'Надішліть опис задачі — які споживачі, яке навантаження, які режими роботи. Розробимо принципову схему самостійно та узгодимо з вами перед початком виготовлення.' },
    { q: 'Чи можна замовити тільки програму без щита?',   a: 'Так. Якщо контролер вже встановлений або щит збирає інша організація — розробляємо та завантажуємо програму окремо. Для цього потрібні паспортні дані контролера і технічне завдання на алгоритм роботи.' },
    { q: 'Які задачі ви беретеся автоматизувати?',        a: 'Беремося за задачі малої та середньої складності — автоматизація окремого процесу, цеху або невеликої виробничої лінії. Наприклад: керування групою двигунів і клапанів за заданим сценарієм, автоматизація насосної станції, вентиляції або протипожежної системи.' },
    { q: 'Як описати задачу, якщо я не знаю що мені потрібно?', a: 'Опишіть що повинна робити система — словами, без технічних деталей. Що вмикається, що вимикається, за якою умовою, що має відбутися в аварійній ситуації. Цього достатньо, щоб ми могли оцінити задачу і запропонувати рішення.' },
    { q: 'Чи потрібен ПЛК, чи достатньо релейної схеми?', a: 'Залежить від задачі. Якщо сигналів і вузлів небагато — реалізуємо на релейно-контакторній схемі: це надійно і дешевше. Якщо логіка складна або вузлів багато — інтегруємо ПЛК і розробляємо програму під задачу.' },
    { q: 'Яку документацію ви передаєте разом зі щитом?', a: 'Паспорт виробу та принципову схему. Документи вкладаються безпосередньо у щит.' },
    { q: 'Чи можна надати свої компоненти для збірки?',   a: 'Ні. Ми самостійно закуповуємо все обладнання відповідно до узгодженої специфікації і передаємо замовнику готовий виріб з гарантією. Це дозволяє нам відповідати за якість щита від початку до кінця.' },
  ],
};
---
<ProductLayout
  {page}
  slug="plk"
  {hero}
  {gallery}
  {objects}
  {specs}
  {steps}
  {why}
  {faq}
  contactTitle="Готові обговорити ваше замовлення — програмування ПЛК"
>
  <!-- extra1: Контролери — білий фон (таблиця вже всередині specs, але тут додатковий текст) -->
  <section slot="extra1" class="em-section">
    <span class="em-section-label">Контролери</span>
    <h2>З якими контролерами працюємо</h2>
    <table class="em-specs-table">
      <tbody>
        <tr><td class="em-specs-label">Siemens LOGO!</td><td class="em-specs-value">Компактні задачі: керування 1–3 вузлами, прості алгоритми, таймери, лічильники</td></tr>
        <tr><td class="em-specs-label">Schneider Electric Zelio Logic</td><td class="em-specs-value">Аналог LOGO! — застосовуємо залежно від наявності та побажань замовника</td></tr>
        <tr><td class="em-specs-label">Eaton Easy (Easy-E4)</td><td class="em-specs-value">Компактні рішення для невеликих установок</td></tr>
        <tr><td class="em-specs-label">ОВЕН</td><td class="em-specs-value">Вітчизняний виробник, широко застосовується на українських підприємствах</td></tr>
      </tbody>
    </table>
    <p style="margin-top:16px; color:var(--c-muted); font-family:var(--ff-body); font-size:14px;">Якщо у вас інший контролер — уточніть при подачі ТЗ, розглянемо індивідуально.</p>
  </section>

  <!-- extra2: Формати роботи — зелений фон -->
  <div slot="extra2" class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Формати роботи</span>
      <h2>Окремо або разом зі щитом</h2>
      <div class="em-why-grid">
        <div class="em-why-card">
          <div class="em-why-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
            </svg>
          </div>
          <h3>Щит + програма під ключ</h3>
          <p>Збираємо щит керування з встановленим контролером і розробляємо програму під ваше технічне завдання. Тестуємо все разом перед передачею. Одна відповідальна сторона від початку до кінця.</p>
        </div>
        <div class="em-why-card">
          <div class="em-why-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3>Тільки програма</h3>
          <p>Якщо щит вже є або його збирає інша організація — розробляємо та завантажуємо програму окремо. Потрібні паспортні дані контролера і технічне завдання на алгоритм роботи.</p>
        </div>
      </div>
    </div>
  </div>
</ProductLayout>
