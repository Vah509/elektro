---
// Блок: теги + H1 + текст опису (через slot)
const TYPE_LABELS: Record<string, string> = {
  hrshch:           'ГРЩ / ВРЩ',
  dymovydalennia:   'Димовидалення',
  dvyhuny:          'Двигуни',
  shuz:             'ШУЗ',
  krm:              'КРМ',
  'zenitni-lihtari':'Зенітні ліхтарі',
  ahro:             'Агро',
  plk:              'ПЛК',
  elektromontazh:   'Електромонтаж',
};

const TAG_LABELS: Record<string, string> = {
  avr:                      'АВР',
  fire:                     'Пожежна автоматика',
  'pryamyi-pusk':           'Прямий пуск',
  'zirka-trykutnyk':        'Зірка-трикутник',
  'chastotnyy-peretvoryuvach': 'Частотний перетворювач',
  'myakyi-pusk':            'М\'який пуск',
  plk:                      'ПЛК',
  agro:                     'Агро',
  promyslovist:             'Промисловість',
  remont:                   'Реконструкція',
};

interface Props {
  title: string;
  types: string[];
  tags: string[];
}
const { title, types, tags } = Astro.props;
---

<div class="em-work-description">
  <!-- Теги — два класи, однаковий вигляд -->
  <div class="em-work-tags">
    {types.map(t => (
      <span class="em-work-tag em-work-tag--type">
        {TYPE_LABELS[t] ?? t}
      </span>
    ))}
    {tags.map(t => (
      <span class="em-work-tag em-work-tag--tag">
        {TAG_LABELS[t] ?? t}
      </span>
    ))}
  </div>

  <!-- Заголовок -->
  <h1 class="em-work-title">{title}</h1>

  <!-- Текст опису — рендериться через slot -->
  <div class="em-work-body">
    <slot />
  </div>
</div>

<style>
.em-work-description {
  max-width: 900px;
  margin: 0 auto;
  padding: 32px 24px 40px;
}
.em-work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 16px;
}
.em-work-tag {
  display: inline-block;
  background: var(--c-accent-faint);
  border: 1px solid var(--c-accent-border);
  border-radius: 20px;
  padding: 4px 12px;
  font-size: 12px;
  font-weight: 600;
  color: var(--c-accent);
  font-family: var(--ff-body);
  white-space: nowrap;
}
.em-work-tag--type {}
.em-work-tag--tag  {}

.em-work-title {
  font-size: clamp(24px, 4vw, 36px);
  margin-bottom: 18px;
  color: var(--c-head);
}
.em-work-body {
  font-family: var(--ff-body);
  font-size: 15px;
  color: var(--c-muted);
  line-height: 1.75;
}
.em-work-body p { margin-bottom: 14px; }
.em-work-body p:last-child { margin-bottom: 0; }

@media (max-width: 600px) {
  .em-work-description { padding: 24px 16px 32px; }
}
</style>
