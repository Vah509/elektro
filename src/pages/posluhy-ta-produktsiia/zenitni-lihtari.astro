---
import { PHONE, PHONE_DISPLAY, SITE_CANONICAL } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import AlsoMake from '../../components/AlsoMake.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import Lightbox from '../../components/Lightbox.astro';

const page = {
  section:     'produktsiia',
  title:       'Щити керування зенітними ліхтарями на замовлення | elektroschit.com.ua',
  description: 'Виготовлення щитів керування зенітними ліхтарями, фрамугами та люками. Автоматичне відкриття від пожежної сигналізації. Гарантія 12 місяців. Київ та вся Україна.',
  canonical:   `${SITE_CANONICAL}/posluhy-ta-produktsiia/zenitni-lihtari/`,
  crumbs: [
    { label: 'Головна',   href: '/' },
    { label: 'Продукція', href: '/posluhy-ta-produktsiia/' },
    { label: 'Щити керування зенітними ліхтарями' },
  ],
};

const faqItems = [
  { q: "Що робити, якщо готової схеми немає?", a: "Надішліть опис задачі — скільки зенітних ліхтарів або фрамуг, які приводи, які режими роботи потрібні. Розробимо принципову схему самостійно та узгодимо з вами перед початком виготовлення." },
  { q: "Чи можна надати свої компоненти для збірки?", a: "Ні. Ми самостійно закуповуємо все обладнання відповідно до узгодженої специфікації і передаємо замовнику готовий виріб з гарантією." },
  { q: "Чи інтегрується щит з пожежною сигналізацією будь-якого виробника?", a: "Так. Працюємо від сигналу будь-якої АУПС — як правило це нормально-відкритий або нормально-закритий контакт." },
  { q: "Чи можна керувати кількома зонами незалежно?", a: "Так. Реалізуємо незалежне зональне керування — кожна група ліхтарів або фрамуг спрацьовує окремо. Кількість зон визначається проєктом або технічним завданням." },
  { q: "Чи можна організувати провітрювання за розкладом?", a: "Так, якщо в схемі передбачений таймер або ПЛК. Реалізуємо автоматичне відкриття/закриття за часовою програмою — наприклад, для провітрювання на початку і в кінці робочого дня." },
  { q: "Яку документацію ви передаєте разом зі щитом?", a: "Паспорт виробу та принципову схему. Документи вкладаються безпосередньо у щит." },
  { q: "Який термін виготовлення?", a: "Від 2 тижнів. Точний термін узгоджується після отримання технічного завдання або схеми." },
];
---
<BaseLayout {page}>
  <link slot="head" rel="stylesheet" href="/css/em-hrshch.css" />

  <div class="em-hero-product">
    <div class="em-hero-product-inner">
      <div class="em-hero-product-text">
        <h1>Виготовлення щитів керування зенітними ліхтарями на замовлення</h1>
        <p class="em-hero-product-lead">Виготовляємо щити керування зенітними ліхтарями, фрамугами та люками для промислових і комерційних будівель. Автоматичне відкриття від пожежної сигналізації, ручне і дистанційне керування — під ваше технічне завдання. Київ, Київська область та вся Україна.</p>
        <div class="em-hero-badges">
          <div class="em-badge"><strong>від 1 зони</strong> і більше</div>
          <div class="em-badge"><strong>від 2 тижнів</strong> — виготовлення</div>
          <div class="em-badge"><strong>12 міс.</strong> — гарантія</div>
          <div class="em-badge"><strong>25 років</strong> — досвід</div>
        </div>
        <div class="em-hero-product-actions">
          <a href="#kontakty-blok" class="em-btn-primary">Замовити / Зв'язатися з нами</a>
        </div>
        <p class="em-hero-product-contact">Або зателефонуйте: <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></p>
      </div>
      <div class="em-hero-collage">
        <div class="em-hero-collage-item"><img src="/images/zenitni-lihtari/zenitni-lihtari-fasad-shchyt-kyiv-2026-06-c1.jpg" alt="Щит керування зенітними ліхтарями — фасад з кнопками та перемикачами" loading="eager" /></div>
        <div class="em-hero-collage-item"><img src="/images/zenitni-lihtari/zenitni-lihtari-vnutrishnii-montazh-kyiv-2026-06-c2.jpg" alt="Внутрішній монтаж щита керування зенітними ліхтарями" loading="eager" /></div>
        <div class="em-hero-collage-item"><img src="/images/zenitni-lihtari/zenitni-lihtari-plk-ovr-pr100-kyiv-2026-06-c3.jpg" alt="Щит з ПЛК OVR PR-100 для керування зенітними ліхтарями" loading="lazy" /></div>
        <div class="em-hero-collage-item"><img src="/images/zenitni-lihtari/zenitni-lihtari-rele-kontaktory-kyiv-2026-06-c4.jpg" alt="Реле та контактори у щиті керування зенітними ліхтарями" loading="lazy" /></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Наші роботи</span>
    <h2>Виготовлення щитів для зенітних ліхтарів — фото з виробництва</h2>
    <div class="em-product-gallery">
      <div class="em-gallery-item em-gallery-item-large" data-caption="Щит керування зенітними ліхтарями — загальний вигляд відкритого щита" data-full="/images/zenitni-lihtari/zenitni-lihtari-zahalnyi-vyhlyad-kyiv-2026-06-01.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-zahalnyi-vyhlyad-kyiv-2026-06-01.jpg" alt="Щит керування зенітними ліхтарями — загальний вигляд" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Фасад щита — перемикачі Авт/Руч, кнопки Відкрити/Закрити, лампи індикації по зонах" data-full="/images/zenitni-lihtari/zenitni-lihtari-fasad-shchyt-kyiv-2026-06-02.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-fasad-shchyt-kyiv-2026-06-02.jpg" alt="Фасад щита керування зенітними ліхтарями" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Внутрішній монтаж — автомати QF, контактори KM, реле K, клемні колодки" data-full="/images/zenitni-lihtari/zenitni-lihtari-vnutrishnii-montazh-kyiv-2026-06-03.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-vnutrishnii-montazh-kyiv-2026-06-03.jpg" alt="Внутрішній монтаж щита зенітних ліхтарів" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="ПЛК OVR PR-100 — програмований логічний контролер для керування зонами ліхтарів" data-full="/images/zenitni-lihtari/zenitni-lihtari-plk-ovr-pr100-kyiv-2026-06-04.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-plk-ovr-pr100-kyiv-2026-06-04.jpg" alt="ПЛК OVR PR-100 у щиті керування зенітними ліхтарями" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Реле керування K1–K4 та контактори KM1–KM2 — нижня секція монтажу" data-full="/images/zenitni-lihtari/zenitni-lihtari-rele-kontaktory-kyiv-2026-06-05.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-rele-kontaktory-kyiv-2026-06-05.jpg" alt="Реле та контактори у щиті зенітних ліхтарів" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Клемні колодки з маркуванням — підключення приводів зенітних ліхтарів" data-full="/images/zenitni-lihtari/zenitni-lihtari-klemy-markuvannia-kyiv-2026-06-06.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-klemy-markuvannia-kyiv-2026-06-06.jpg" alt="Клемні колодки та маркування у щиті зенітних ліхтарів" width="1200" height="900" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Готовий щит — закритий, підготовлений до відправки замовнику" data-full="/images/zenitni-lihtari/zenitni-lihtari-gotovyi-shchyt-kyiv-2026-06-07.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-gotovyi-shchyt-kyiv-2026-06-07.jpg" alt="Готовий щит керування зенітними ліхтарями" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Принципова схема всередині дверцят — для зручного обслуговування" data-full="/images/zenitni-lihtari/zenitni-lihtari-skhema-dvirtsi-kyiv-2026-06-08.jpg"><img src="/images/zenitni-lihtari/zenitni-lihtari-skhema-dvirtsi-kyiv-2026-06-08.jpg" alt="Принципова схема на дверцятах щита зенітних ліхтарів" width="900" height="1200" loading="lazy" /></div>
    </div>
    <div class="em-gallery-cta"><a href="/vykonani-roboty/" class="em-btn-primary">Переглянути роботи →</a></div>
  </section>

  <div class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Застосування</span>
      <h2>Де застосовуються щити керування зенітними ліхтарями</h2>
      <p class="em-lead">Встановлюються на будівлях з природним освітленням або вентиляцією через покрівлю.</p>
      <div class="em-objects-grid">
        <div class="em-object-card"><div class="em-object-num">01</div><h3>Складські та логістичні комплекси</h3><p>Природне освітлення та аварійне провітрювання при пожежі через покрівельні ліхтарі.</p></div>
        <div class="em-object-card"><div class="em-object-num">02</div><h3>Виробничі цехи</h3><p>Природна вентиляція та аварійне димовидалення через зенітні ліхтарі або люки покрівлі.</p></div>
        <div class="em-object-card"><div class="em-object-num">03</div><h3>Торгові центри та атріуми</h3><p>Автоматичне відкриття при пожежі або провітрювання в теплу пору за розкладом.</p></div>
        <div class="em-object-card"><div class="em-object-num">04</div><h3>Спортивні та виставкові зали</h3><p>Велика площа даху — природне освітлення та провітрювання з автоматичним керуванням.</p></div>
        <div class="em-object-card"><div class="em-object-num">05</div><h3>Агропромислові об'єкти</h3><p>Зернові комплекси, тепличні господарства — природна вентиляція та регуляція мікроклімату.</p></div>
        <div class="em-object-card"><div class="em-object-num">06</div><h3>Підрядні організації</h3><p>Електромонтажні компанії, які ведуть монтаж систем природного освітлення та вентиляції.</p></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Характеристики</span>
    <h2>Технічні характеристики щита керування зенітними ліхтарями</h2>
    <table class="em-specs-table">
      <tbody>
        <tr><td class="em-specs-label">Кількість зон керування</td><td class="em-specs-value">від 1 і більше — за проєктом або ТЗ</td></tr>
        <tr><td class="em-specs-label">Типи приводів</td><td class="em-specs-value">Електромеханічні приводи фрамуг будь-яких виробників</td></tr>
        <tr><td class="em-specs-label">Режими керування</td><td class="em-specs-value">Автоматичний (від АУПС) / Ручний / Дистанційний</td></tr>
        <tr><td class="em-specs-label">Керування за часовою програмою</td><td class="em-specs-value">За потребою — через таймер або ПЛК</td></tr>
        <tr><td class="em-specs-label">Виготовлення за схемами замовника</td><td class="em-specs-value">Так</td></tr>
        <tr><td class="em-specs-label">Розробка схем під ТЗ</td><td class="em-specs-value">Так</td></tr>
        <tr><td class="em-specs-label">Гарантія</td><td class="em-specs-value">12 місяців</td></tr>
        <tr><td class="em-specs-label">Терміни виготовлення</td><td class="em-specs-value">від 2 тижнів</td></tr>
        <tr><td class="em-specs-label">Доставка</td><td class="em-specs-value">Київ, Київська область, вся Україна</td></tr>
      </tbody>
    </table>
  </section>

  <div class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Компоненти</span>
      <h2>Компоненти та виробники</h2>
      <p class="em-lead">Підбираємо під бюджет та наявність. Конкретний бренд узгоджується при прийомі замовлення.</p>
      <div class="em-brands">
        <div class="em-brands-group"><div class="em-brands-group-label">Основні бренди</div><div class="em-brands-row"><div class="em-brand-pill">ETI</div><div class="em-brand-pill">Hager</div><div class="em-brand-pill">Schneider Electric</div><div class="em-brand-pill">Eaton</div></div></div>
        <div class="em-brands-group"><div class="em-brands-group-label">Економ-комплектація</div><div class="em-brands-row"><div class="em-brand-pill secondary">E-Next</div><div class="em-brand-pill secondary">Asko</div><div class="em-brand-pill secondary">Chint</div></div></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Переваги</span>
    <h2>Чому замовляють у нас</h2>
    <div class="em-why-grid">
      <div class="em-why-card"><h3>Досвід з 1999 року</h3><p>25+ років виготовлення щитів для промислових та комерційних об'єктів.</p></div>
      <div class="em-why-card"><h3>Робота за проєктною документацією</h3><p>Приймаємо схеми від будь-якої проєктної організації та збираємо точно за ними.</p></div>
      <div class="em-why-card"><h3>Розробляємо схеми самостійно</h3><p>Якщо немає проєкту — надішліть ТЗ або опис задачі. Розробимо схему та узгодимо з вами.</p></div>
      <div class="em-why-card"><h3>Тестування перед відправкою</h3><p>Кожен щит перевіряється до передачі замовнику. Паспорт виробу — з кожним щитом.</p></div>
      <div class="em-why-card"><h3>Доставка по всій Україні</h3><p>По Києву та Київській обл. — власним транспортом. По Україні — Новою Поштою.</p></div>
      <div class="em-why-card"><h3>Гарантія 12 місяців</h3><p>На кожен виготовлений щит — письмове гарантійне зобов'язання.</p></div>
    </div>
  </section>

  <FaqAccordion items={faqItems} sectionTitle="Питання про щити керування зенітними ліхтарями" />
  <ContactBlock title="Готові обговорити ваше замовлення — щит керування зенітними ліхтарями" />
  <AlsoMake currentSlug="zenitni-lihtari" />
  <Lightbox />
  <script is:inline src="/js/em-site.js"></script>
</BaseLayout>
