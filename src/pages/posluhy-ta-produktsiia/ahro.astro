---
import { PHONE, PHONE_DISPLAY, SITE_CANONICAL } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import AlsoMake from '../../components/AlsoMake.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import Lightbox from '../../components/Lightbox.astro';

const page = {
  section:     'produktsiia',
  title:       'Електрощити для агрогосподарств на замовлення | elektroschit.com.ua',
  description: 'Виготовлення електрощитів для агрогосподарств: вентиляція, аерація, кормові системи, насоси. Захист від вологи та агресивного середовища. Гарантія 12 міс. Київ та вся Україна.',
  canonical:   `${SITE_CANONICAL}/posluhy-ta-produktsiia/ahro/`,
  crumbs: [
    { label: 'Головна',   href: '/' },
    { label: 'Продукція', href: '/posluhy-ta-produktsiia/' },
    { label: 'Електрощити для агрогосподарств' },
  ],
};

const faqItems = [
  { q: "Що робити, якщо готової схеми немає?", a: "Надішліть опис задачі — які споживачі, яке навантаження, які режими роботи потрібні. Розробимо принципову схему самостійно та узгодимо з вами перед початком виготовлення." },
  { q: "Чи підходять щити для роботи в умовах підвищеної вологості та пилу?", a: "Так. Для агрооб'єктів підбираємо корпуси з підвищеним ступенем захисту IP54–IP65, стійкі до вологи, пилу та агресивного середовища." },
  { q: "Чи можна керувати кількома групами споживачів з одного щита?", a: "Так. Реалізуємо незалежне керування кількома групами — наприклад, вентилятори + обігрівачі + кормові шнеки — в одному щиті зі спільним вводом живлення." },
  { q: "Чи є можливість автоматичного керування за датчиками?", a: "Так. Реалізуємо керування від датчиків температури, вологості, рівня зерна або тиску — через реле або ПЛК залежно від складності задачі." },
  { q: "Чи можна надати свої компоненти для збірки?", a: "Ні. Ми самостійно закуповуємо все обладнання відповідно до узгодженої специфікації і передаємо замовнику готовий виріб з гарантією." },
  { q: "Яку документацію ви передаєте разом зі щитом?", a: "Паспорт виробу та принципову схему. Документи вкладаються безпосередньо у щит." },
  { q: "Який термін виготовлення?", a: "Від 2 тижнів. Точний термін узгоджується після отримання технічного завдання або схеми." },
];
---
<BaseLayout {page}>
  <link slot="head" rel="stylesheet" href="/css/em-hrshch.css" />

  <div class="em-hero-product">
    <div class="em-hero-product-inner">
      <div class="em-hero-product-text">
        <h1>Виготовлення електрощитів для агрогосподарств на замовлення</h1>
        <p class="em-hero-product-lead">Виготовляємо електрощити для агропромислових об'єктів: керування вентиляцією, аерацією, кормовими системами, насосами та іншими споживачами. Захист від вологи та агресивного середовища. Київ, Київська область та вся Україна.</p>
        <div class="em-hero-badges">
          <div class="em-badge"><strong>IP54–IP65</strong> — захист корпусу</div>
          <div class="em-badge"><strong>від 2 тижнів</strong> — виготовлення</div>
          <div class="em-badge"><strong>12 міс.</strong> — гарантія</div>
          <div class="em-badge"><strong>25 років</strong> — досвід</div>
        </div>
        <div class="em-hero-product-actions">
          <a href="#kontakty-blok" class="em-btn-primary">Замовити / Зв'язатися з нами</a>
        </div>
        <p class="em-hero-product-contact">Або зателефонуйте: <a href={`tel:${PHONE}`}>{PHONE_DISPLAY}</a></p>
      </div>
      <div class="em-hero-collage">
        <div class="em-hero-collage-item"><img src="/images/ahro/ahro-shchyt-ventilyatsiya-fasad-kyiv-2026-06-c1.jpg" alt="Електрощит агро — керування вентиляцією, фасад" loading="eager" /></div>
        <div class="em-hero-collage-item"><img src="/images/ahro/ahro-shchyt-vnutrishnii-montazh-kyiv-2026-06-c2.jpg" alt="Внутрішній монтаж агрощита — контактори, автомати, клеми" loading="eager" /></div>
        <div class="em-hero-collage-item"><img src="/images/ahro/ahro-shchyt-aeratsiya-kyiv-2026-06-c3.jpg" alt="Щит керування аераторами — зерносховище" loading="lazy" /></div>
        <div class="em-hero-collage-item"><img src="/images/ahro/ahro-shchyt-ip65-korpus-kyiv-2026-06-c4.jpg" alt="Щит у корпусі IP65 — для вологого середовища агропідприємства" loading="lazy" /></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Наші роботи</span>
    <h2>Електрощити для агрогосподарств — фото з нашого виробництва</h2>
    <div class="em-product-gallery">
      <div class="em-gallery-item em-gallery-item-large" data-caption="Щит керування вентиляцією агрокомплексу — загальний вигляд відкритого щита" data-full="/images/ahro/ahro-shchyt-ventilyatsiya-zahalnyi-kyiv-2026-06-01.jpg"><img src="/images/ahro/ahro-shchyt-ventilyatsiya-zahalnyi-kyiv-2026-06-01.jpg" alt="Щит керування вентиляцією агрокомплексу" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Внутрішній монтаж агрощита — контактори ETI, автомати QF, клемні колодки" data-full="/images/ahro/ahro-vnutrishnii-montazh-kontaktory-kyiv-2026-06-02.jpg"><img src="/images/ahro/ahro-vnutrishnii-montazh-kontaktory-kyiv-2026-06-02.jpg" alt="Внутрішній монтаж агрощита — контактори ETI та автомати" width="1200" height="900" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Щит керування аераторами — зерносховище, 4 аератори, авт/ручний режим" data-full="/images/ahro/ahro-aeratsiya-4-aeratory-kyiv-2026-06-03.jpg"><img src="/images/ahro/ahro-aeratsiya-4-aeratory-kyiv-2026-06-03.jpg" alt="Щит керування аераторами зерносховища — 4 аератори" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Захищений корпус IP65 для встановлення у вологих та пилових приміщеннях" data-full="/images/ahro/ahro-korpus-ip65-vologyi-kyiv-2026-06-04.jpg"><img src="/images/ahro/ahro-korpus-ip65-vologyi-kyiv-2026-06-04.jpg" alt="Агрощит у захищеному корпусі IP65" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Частотний перетворювач WEG у щиті агрокомплексу — м'який пуск аератора" data-full="/images/ahro/ahro-chastotnyy-weg-aerator-kyiv-2026-06-05.jpg"><img src="/images/ahro/ahro-chastotnyy-weg-aerator-kyiv-2026-06-05.jpg" alt="Частотний перетворювач WEG у щиті керування аераторами" width="900" height="1200" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Кормова система — щит керування шнеками та транспортерами агрокомплексу" data-full="/images/ahro/ahro-kormova-systema-shneka-kyiv-2026-06-06.jpg"><img src="/images/ahro/ahro-kormova-systema-shneka-kyiv-2026-06-06.jpg" alt="Щит керування кормовою системою — шнеки агрокомплексу" width="1200" height="900" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Клемні колодки з маркуванням — підключення споживачів агрощита" data-full="/images/ahro/ahro-klemy-markuvannia-kyiv-2026-06-07.jpg"><img src="/images/ahro/ahro-klemy-markuvannia-kyiv-2026-06-07.jpg" alt="Клемні колодки з маркуванням у агрощиті" width="1200" height="900" loading="lazy" /></div>
      <div class="em-gallery-item" data-caption="Готовий агрощит — закритий, підготовлений до відправки на об'єкт" data-full="/images/ahro/ahro-gotovyi-shchyt-vidpravka-kyiv-2026-06-08.jpg"><img src="/images/ahro/ahro-gotovyi-shchyt-vidpravka-kyiv-2026-06-08.jpg" alt="Готовий електрощит для агрогосподарства" width="900" height="1200" loading="lazy" /></div>
    </div>
    <div class="em-gallery-cta"><a href="/vykonani-roboty/" class="em-btn-primary">Переглянути роботи →</a></div>
  </section>

  <div class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Застосування</span>
      <h2>Для яких агрооб'єктів виготовляємо щити</h2>
      <p class="em-lead">Агропромислові об'єкти мають специфічні вимоги до електрообладнання — підвищена вологість, пил, агресивне середовище, сезонна зміна навантажень.</p>
      <div class="em-objects-grid">
        <div class="em-object-card"><div class="em-object-num">01</div><h3>Зернові комплекси та елеватори</h3><p>Керування аераторами, транспортерами, нориями та сушарками зерна.</p></div>
        <div class="em-object-card"><div class="em-object-num">02</div><h3>Тваринницькі комплекси</h3><p>Вентиляція та опалення свинарників, корівників, птахофабрик. Кормові системи та водопостачання.</p></div>
        <div class="em-object-card"><div class="em-object-num">03</div><h3>Насосні станції</h3><p>Зрошення, водопостачання агропідприємств — керування насосами з автоматичним або ручним режимом.</p></div>
        <div class="em-object-card"><div class="em-object-num">04</div><h3>Тепличні господарства</h3><p>Керування освітленням, вентиляцією, опаленням та поливними системами теплиць.</p></div>
        <div class="em-object-card"><div class="em-object-num">05</div><h3>Сушарки та сортувальні лінії</h3><p>Технологічні лінії з кількома споживачами та блокуваннями — реалізуємо на реле або ПЛК.</p></div>
        <div class="em-object-card"><div class="em-object-num">06</div><h3>Підрядні організації</h3><p>Електромонтажні компанії, які ведуть роботи на агрооб'єктах і потребують щит за схемою замовника.</p></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Характеристики</span>
    <h2>Технічні характеристики електрощитів для агро</h2>
    <table class="em-specs-table">
      <tbody>
        <tr><td class="em-specs-label">Ступінь захисту корпусу</td><td class="em-specs-value">IP54–IP65 — залежно від умов середовища</td></tr>
        <tr><td class="em-specs-label">Напруга живлення</td><td class="em-specs-value">220В / 380В</td></tr>
        <tr><td class="em-specs-label">Типи споживачів</td><td class="em-specs-value">Вентилятори, насоси, шнеки, аератори, обігрівачі</td></tr>
        <tr><td class="em-specs-label">Режими керування</td><td class="em-specs-value">Ручний / Автоматичний / Від датчиків</td></tr>
        <tr><td class="em-specs-label">Автоматизація</td><td class="em-specs-value">Від датчиків температури, вологості, рівня — за ТЗ</td></tr>
        <tr><td class="em-specs-label">Виготовлення за схемами замовника</td><td class="em-specs-value">Так</td></tr>
        <tr><td class="em-specs-label">Розробка схем під ТЗ</td><td class="em-specs-value">Так</td></tr>
        <tr><td class="em-specs-label">Гарантія</td><td class="em-specs-value">12 місяців</td></tr>
        <tr><td class="em-specs-label">Терміни виготовлення</td><td class="em-specs-value">від 2 тижнів</td></tr>
        <tr><td class="em-specs-label">Доставка</td><td class="em-specs-value">Київ, Київська область, вся Україна</td></tr>
      </tbody>
    </table>
  </section>

  <div class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Компоненти</span>
      <h2>Компоненти та виробники</h2>
      <p class="em-lead">Підбираємо під бюджет та наявність. Конкретний бренд узгоджується при прийомі замовлення.</p>
      <div class="em-brands">
        <div class="em-brands-group"><div class="em-brands-group-label">Основні бренди</div><div class="em-brands-row"><div class="em-brand-pill">ETI</div><div class="em-brand-pill">Hager</div><div class="em-brand-pill">Schneider Electric</div><div class="em-brand-pill">Eaton</div></div></div>
        <div class="em-brands-group"><div class="em-brands-group-label">Економ-комплектація</div><div class="em-brands-row"><div class="em-brand-pill secondary">E-Next</div><div class="em-brand-pill secondary">Asko</div><div class="em-brand-pill secondary">Chint</div></div></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Переваги</span>
    <h2>Чому замовляють у нас</h2>
    <div class="em-why-grid">
      <div class="em-why-card"><h3>Досвід з 1999 року</h3><p>25+ років виготовлення щитів для промислових та агропромислових об'єктів.</p></div>
      <div class="em-why-card"><h3>Корпуси для агресивного середовища</h3><p>Підбираємо корпуси з підвищеним ступенем захисту IP для роботи у вологих, запилених та хімічно агресивних середовищах.</p></div>
      <div class="em-why-card"><h3>Розробляємо схеми самостійно</h3><p>Якщо немає проєкту — надішліть опис задачі. Розробимо схему та узгодимо з вами.</p></div>
      <div class="em-why-card"><h3>Тестування перед відправкою</h3><p>Кожен щит перевіряється до передачі замовнику. Паспорт виробу — з кожним щитом.</p></div>
      <div class="em-why-card"><h3>Доставка по всій Україні</h3><p>По Києву та Київській обл. — власним транспортом. По Україні — Новою Поштою.</p></div>
      <div class="em-why-card"><h3>Гарантія 12 місяців</h3><p>На кожен виготовлений щит — письмове гарантійне зобов'язання.</p></div>
    </div>
  </section>

  <FaqAccordion items={faqItems} sectionTitle="Питання про електрощити для агрогосподарств" />
  <ContactBlock title="Готові обговорити ваше замовлення — електрощит для агро" />
  <AlsoMake currentSlug="ahro" />
  <Lightbox />
  <script is:inline src="/js/em-site.js"></script>
</BaseLayout>
