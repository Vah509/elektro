const why = {
  h2:    'Почему заказывают у нас',
  cards: [
    { title: 'Опыт с 1999 года',                   text: '25+ лет изготовления щитов для промышленных и коммерческих объектов.' },
    { title: 'Работа по проектной документации',    text: 'Принимаем схемы от любой проектной организации и собираем строго по ним.' },
