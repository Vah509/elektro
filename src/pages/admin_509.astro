---
import { getCollection } from 'astro:content';
import { TYPE_LABELS, TAG_LABELS, PROPERTY_LABELS } from '../data/tags-registry';
import { SITE_PREVIEW, GITHUB_CONTENT_BASE } from '../config';

const allWorks = await getCollection('vykonani-roboty');

const works = allWorks
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const GITHUB_BASE = GITHUB_CONTENT_BASE;
const SITE_BASE = `${SITE_PREVIEW}/vykonani-roboty`;
---
<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Адмін — Виконані роботи</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Geologica:wght@700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --accent: #0f5c30; --accent-b: rgba(15,92,48,0.22); --accent-f: rgba(15,92,48,0.07);
      --bg2: #f2f7f4; --muted: #6b7280; --head: #0f172a; --text: #111827;
      --div: rgba(15,92,48,0.12);
      --ff: 'Geologica', sans-serif; --ffb: 'Manrope', sans-serif;
    }
    body { font-family: var(--ffb); color: var(--text); background: #f8faf9; font-size: 14px; -webkit-font-smoothing: antialiased; }

    /* ── HEADER ── */
    .adm-header {
      background: var(--head); color: #fff; padding: 14px 20px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .adm-header h1 { font-family: var(--ff); font-size: 16px; font-weight: 700; }
    .adm-header span { font-size: 11px; opacity: .45; }

    /* ── STATS ── */
    .adm-stats {
      background: #fff; border-bottom: 1.5px solid var(--accent-b);
      padding: 12px 20px; display: flex; gap: 20px; flex-wrap: wrap;
    }
    .adm-stat { display: flex; flex-direction: column; gap: 1px; }
    .adm-stat-val { font-family: var(--ff); font-size: 20px; font-weight: 700; color: var(--accent); }
    .adm-stat-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }

    /* ── FILTER BAR ── */
    .adm-filter-bar {
      background: #fff; border-bottom: 1.5px solid var(--accent-b);
      padding: 10px 20px; display: flex; flex-direction: column; gap: 8px;
    }
    .adm-filter-group { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .adm-filter-group-label {
      font-size: 10px; font-weight: 700; color: var(--muted);
      text-transform: uppercase; letter-spacing: .06em;
      white-space: nowrap; min-width: 64px;
    }
    .adm-filter-pills { display: flex; flex-wrap: wrap; gap: 4px; }

    .adm-fpill {
      display: inline-flex; align-items: center; gap: 5px;
      border: none; border-radius: 20px; padding: 3px 10px;
      font-family: var(--ffb); font-size: 11px; font-weight: 600;
      cursor: pointer; transition: opacity .15s, box-shadow .15s;
    }
    .adm-fpill:hover { opacity: .8; }
    .adm-fpill.active { box-shadow: 0 0 0 2px var(--accent); }

    .adm-fpill-type  { background: var(--accent-f); border: 1px solid var(--accent-b); color: var(--accent); }
    .adm-fpill-tag   { background: #fff; border: 1px solid var(--accent-b); color: var(--accent); }
    .adm-fpill-prop  { background: transparent; border: 1px solid var(--div); color: var(--muted); }

    .adm-fpill-count {
      background: rgba(0,0,0,0.08); border-radius: 10px;
      padding: 0 5px; font-size: 10px; font-weight: 700;
    }

    /* ── SEARCH ── */
    .adm-search-wrap {
      padding: 12px 20px; background: #fff;
      border-bottom: 1px solid var(--div);
    }
    .adm-search-row {
      display: flex; align-items: center; gap: 14px; flex-wrap: wrap;
    }
    .adm-search {
      width: 100%; max-width: 360px; padding: 8px 12px;
      border: 1.5px solid var(--accent-b); border-radius: 8px;
      font-family: var(--ffb); font-size: 14px; color: var(--text); outline: none;
    }
    .adm-search:focus { border-color: var(--accent); }

    .adm-invert-label {
      display: flex; align-items: center; gap: 6px;
      font-size: 13px; font-weight: 600; color: var(--muted);
      cursor: pointer; user-select: none; white-space: nowrap;
    }
    .adm-invert-label input { width: 15px; height: 15px; accent-color: var(--accent); cursor: pointer; }
    .adm-invert-label:has(input:checked) { color: var(--accent); }

    /* ── PILLS ── */
    .pills { display: flex; flex-wrap: wrap; gap: 4px; }
    .pill { display: inline-block; border-radius: 20px; padding: 2px 8px; font-size: 11px; font-weight: 600; white-space: nowrap; }
    .pill-type { background: var(--accent-f); border: 1px solid var(--accent-b); color: var(--accent); }
    .pill-tag  { background: #fff; border: 1px solid var(--accent-b); color: var(--accent); }
    .pill-prop { background: transparent; border: 1px solid var(--div); color: var(--muted); }
    .pill-none { color: var(--div); font-size: 11px; }

    /* ── BUTTONS ── */
    .btn-sm {
      display: inline-block; padding: 5px 10px; border-radius: 5px;
      font-size: 11px; font-weight: 600; text-decoration: none;
      font-family: var(--ffb); transition: opacity .2s; margin-right: 4px;
      white-space: nowrap;
    }
    .btn-view { background: var(--accent); color: #fff; }
    .btn-edit { background: var(--head); color: #fff; }
    .btn-sm:hover { opacity: .8; }

    /* ── EMPTY ── */
    .adm-empty { padding: 32px; text-align: center; color: var(--muted); display: none; }

    /* ════════════════════════════════
       МОБІЛЬНИЙ — картки
    ════════════════════════════════ */
    .adm-cards { padding: 12px 16px; display: flex; flex-direction: column; gap: 10px; }

    .adm-card {
      background: #fff; border: 1.5px solid var(--accent-b);
      border-radius: 10px; padding: 14px 16px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .adm-card-top {
      display: flex; align-items: flex-start; justify-content: space-between; gap: 8px;
    }
    .adm-card-id {
      font-family: var(--ff); font-size: 13px; font-weight: 700;
      color: var(--accent); opacity: .5; flex-shrink: 0;
    }
    .adm-card-actions { display: flex; gap: 4px; flex-shrink: 0; }
    .adm-card-title {
      font-weight: 700; font-size: 14px; color: var(--head); line-height: 1.3;
    }
    .adm-card-slug {
      font-family: monospace; font-size: 11px; color: var(--muted);
      word-break: break-all;
    }
    .adm-card-meta {
      display: flex; align-items: center; gap: 8px;
      font-size: 11px; color: var(--muted);
    }
    .adm-card-photos { font-weight: 700; color: var(--accent); }

    /* ════════════════════════════════
       ДЕСКТОП — таблиця
    ════════════════════════════════ */
    .adm-table-wrap { display: none; }

    @media (min-width: 900px) {
      .adm-cards { display: none; }
      .adm-table-wrap {
        display: block;
        max-width: 1200px; margin: 0 auto; padding: 20px 24px;
      }
      table {
        width: 100%; border-collapse: collapse; background: #fff;
        border: 1.5px solid var(--accent-b); border-radius: 10px; overflow: hidden;
      }
      thead { background: var(--bg2); }
      th {
        padding: 10px 12px; text-align: left; font-size: 11px; font-weight: 700;
        color: var(--muted); text-transform: uppercase; letter-spacing: .06em;
        border-bottom: 1.5px solid var(--accent-b); white-space: nowrap;
      }
      td { padding: 10px 12px; border-bottom: 1px solid var(--div); vertical-align: top; }
      tr:last-child td { border-bottom: none; }
      tr:hover td { background: var(--accent-f); }

      .cell-id { font-family: var(--ff); font-size: 13px; font-weight: 700; color: var(--accent); opacity: .5; width: 80px; }
      .cell-title { font-weight: 600; color: var(--head); min-width: 160px; font-size: 13px; }
      .cell-slug { font-family: monospace; font-size: 11px; color: var(--muted); white-space: nowrap; }
      .cell-date { font-size: 11px; color: var(--muted); white-space: nowrap; }
      .cell-photos { text-align: center; font-weight: 700; color: var(--accent); }
      .cell-actions { white-space: nowrap; }

      /* stats та search на десктопі — більше відступи */
      .adm-stats { padding: 14px 24px; gap: 28px; }
      .adm-search-wrap { padding: 14px 24px; }
      .adm-search { max-width: 400px; }
    }
  </style>
</head>
<body>

<div class="adm-header">
  <h1>⚡ Виконані роботи</h1>
  <span>/admin_509/</span>
</div>

<!-- СТАТИСТИКА + ФІЛЬТР-ПЛАШКИ -->
<div class="adm-stats">
  <div class="adm-stat">
    <span class="adm-stat-val">{works.length}</span>
    <span class="adm-stat-label">Карточок</span>
  </div>
</div>

<div class="adm-filter-bar">
  <!-- Розділи -->
  <div class="adm-filter-group">
    <span class="adm-filter-group-label">Розділи</span>
    <div class="adm-filter-pills">
      {Object.keys(TYPE_LABELS).filter(t => works.some(w => w.data.types.includes(t))).map(t => (
        <button type="button" class="adm-fpill adm-fpill-type" data-filter={t}>
          {TYPE_LABELS[t]}
          <span class="adm-fpill-count">{works.filter(w => w.data.types.includes(t)).length}</span>
        </button>
      ))}
    </div>
  </div>
  <!-- Теги -->
  {Object.keys(TAG_LABELS).filter(t => works.some(w => w.data.tags.includes(t))).length > 0 && (
    <div class="adm-filter-group">
      <span class="adm-filter-group-label">Теги</span>
      <div class="adm-filter-pills">
        {Object.keys(TAG_LABELS).filter(t => works.some(w => w.data.tags.includes(t))).map(t => (
          <button type="button" class="adm-fpill adm-fpill-tag" data-filter={t}>
            {TAG_LABELS[t]}
            <span class="adm-fpill-count">{works.filter(w => w.data.tags.includes(t)).length}</span>
          </button>
        ))}
      </div>
    </div>
  )}
  <!-- Властивості -->
  {Object.keys(PROPERTY_LABELS).filter(p => works.some(w => w.data.properties?.includes(p))).length > 0 && (
    <div class="adm-filter-group">
      <span class="adm-filter-group-label">Властивості</span>
      <div class="adm-filter-pills">
        {Object.keys(PROPERTY_LABELS).filter(p => works.some(w => w.data.properties?.includes(p))).map(p => (
          <button type="button" class="adm-fpill adm-fpill-prop" data-filter={p}>
            {PROPERTY_LABELS[p]}
            <span class="adm-fpill-count">{works.filter(w => w.data.properties?.includes(p)).length}</span>
          </button>
        ))}
      </div>
    </div>
  )}
</div>

<!-- ПОШУК -->
<div class="adm-search-wrap">
  <div class="adm-search-row">
    <input type="search" class="adm-search" id="adm-search"
      placeholder="Пошук або натисніть плашку вище..." autocomplete="off" />
    <label class="adm-invert-label">
      <input type="checkbox" id="adm-invert" />
      <span>Інвертувати</span>
    </label>
  </div>
</div>

<!-- МОБІЛЬНИЙ: картки -->
<div class="adm-cards" id="adm-cards">
  {works.map(w => (
    <div class="adm-card" data-search={`${w.data.title} ${w.slug} ${w.data.types.join(' ')} ${w.data.tags.join(' ')} ${(w.data.properties ?? []).join(' ')}`.toLowerCase()}>
      <div class="adm-card-top">
        <span class="adm-card-id">{w.data.id}</span>
        <div class="adm-card-actions">
          <a href={`${SITE_BASE}/${w.slug}/`} target="_blank" class="btn-sm btn-view">↗</a>
          <a href={`${GITHUB_BASE}/${w.slug}.md`} target="_blank" class="btn-sm btn-edit">✎</a>
        </div>
      </div>
      <div class="adm-card-title">{w.data.title}</div>
      <div class="adm-card-slug">{w.slug}</div>
      <div class="pills">
        {w.data.types.map(t => <span class="pill pill-type">{TYPE_LABELS[t] ?? t}</span>)}
        {w.data.tags.map(t => <span class="pill pill-tag">{TAG_LABELS[t] ?? t}</span>)}
        {w.data.properties && w.data.properties.map(p => <span class="pill pill-prop">{PROPERTY_LABELS[p] ?? p}</span>)}
      </div>
      <div class="adm-card-meta">
        <span class="adm-card-photos">📷 {w.data.photos.length}</span>
        <span>·</span>
        <span>{new Date(w.data.date).toLocaleDateString('uk-UA', {day:'2-digit',month:'2-digit',year:'numeric'})}</span>
      </div>
    </div>
  ))}
</div>
<div class="adm-empty" id="adm-empty-mob">Нічого не знайдено</div>

<!-- ДЕСКТОП: таблиця -->
<div class="adm-table-wrap">
  <table id="adm-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Назва</th>
        <th>Slug</th>
        <th>Розділи</th>
        <th>Теги</th>
        <th>Властивості</th>
        <th>Фото</th>
        <th>Дата</th>
        <th>Дії</th>
      </tr>
    </thead>
    <tbody>
      {works.map(w => (
        <tr data-search={`${w.data.title} ${w.slug} ${w.data.types.join(' ')} ${w.data.tags.join(' ')} ${(w.data.properties ?? []).join(' ')}`.toLowerCase()}>
          <td class="cell-id">{w.data.id}</td>
          <td class="cell-title">{w.data.title}</td>
          <td class="cell-slug">{w.slug}</td>
          <td><div class="pills">{w.data.types.map(t => <span class="pill pill-type">{TYPE_LABELS[t] ?? t}</span>)}</div></td>
          <td><div class="pills">
            {w.data.tags.length > 0
              ? w.data.tags.map(t => <span class="pill pill-tag">{TAG_LABELS[t] ?? t}</span>)
              : <span class="pill-none">—</span>}
          </div></td>
          <td><div class="pills">
            {w.data.properties && w.data.properties.length > 0
              ? w.data.properties.map(p => <span class="pill pill-prop">{PROPERTY_LABELS[p] ?? p}</span>)
              : <span class="pill-none">—</span>}
          </div></td>
          <td class="cell-photos">{w.data.photos.length}</td>
          <td class="cell-date">{new Date(w.data.date).toLocaleDateString('uk-UA',{day:'2-digit',month:'2-digit',year:'numeric'})}</td>
          <td class="cell-actions">
            <a href={`${SITE_BASE}/${w.slug}/`} target="_blank" class="btn-sm btn-view">↗ Сайт</a>
            <a href={`${GITHUB_BASE}/${w.slug}.md`} target="_blank" class="btn-sm btn-edit">✎ GitHub</a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
  <div class="adm-empty" id="adm-empty-desk">Нічого не знайдено</div>
</div>

<script is:inline>
  const search   = document.getElementById('adm-search');
  const invert   = document.getElementById('adm-invert');
  const cards    = document.querySelectorAll('.adm-card');
  const rows     = document.querySelectorAll('#adm-table tbody tr');
  const emptyMob  = document.getElementById('adm-empty-mob');
  const emptyDesk = document.getElementById('adm-empty-desk');

  // Головна функція фільтрації
  function applyFilter() {
    const q = search.value.toLowerCase().trim();
    const inv = invert.checked;
    let visCards = 0, visRows = 0;

    cards.forEach(card => {
      const match = !q || card.dataset.search.includes(q);
      const show  = inv ? !match : match;
      card.style.display = show ? '' : 'none';
      if (show) visCards++;
    });
    emptyMob.style.display = visCards === 0 && q ? 'block' : 'none';

    rows.forEach(row => {
      const match = !q || row.dataset.search.includes(q);
      const show  = inv ? !match : match;
      row.style.display = show ? '' : 'none';
      if (show) visRows++;
    });
    emptyDesk.style.display = visRows === 0 && q ? 'block' : 'none';
  }

  // Клік по плашці — вставляє slug у поле пошуку
  document.querySelectorAll('.adm-fpill').forEach(pill => {
    pill.addEventListener('click', () => {
      const val = pill.dataset.filter;

      // Якщо ця плашка вже активна — скидаємо фільтр
      if (pill.classList.contains('active')) {
        search.value = '';
        document.querySelectorAll('.adm-fpill').forEach(p => p.classList.remove('active'));
      } else {
        search.value = val;
        document.querySelectorAll('.adm-fpill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
      }
      applyFilter();
    });
  });

  // Скидаємо підсвітку плашки якщо текст змінили вручну
  search.addEventListener('input', () => {
    document.querySelectorAll('.adm-fpill').forEach(p => p.classList.remove('active'));
    applyFilter();
  });

  invert.addEventListener('change', applyFilter);
</script>

</body>
</html>
