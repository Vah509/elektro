---
import { PHONE, PHONE_DISPLAY, EMAIL, ADDRESS, MAPS_URL, VIBER, TELEGRAM, WHATSAPP, SITE_CANONICAL } from '../../config';
import BaseLayout from '../../layouts/BaseLayout.astro';

const page = {
  lang:        'ru' as const,
  altUrl:      '/kontakty/',
  section:     'kontakty',
  title:       'Контакты — изготовление электрощитов | elektroschit.com.ua',
  description: 'Свяжитесь с производителем электрощитов в Киеве. Телефон, email, Viber, Telegram, WhatsApp. Отвечаем в течение 1–2 рабочих дней. Адрес: ул. Печенежская, 35/43.',
  canonical:   `${SITE_CANONICAL}/ru/kontakty/`,
  crumbs: [
    { label: 'Главная', href: '/ru/' },
    { label: 'Контакты' },
  ],
};
---
<BaseLayout {page}>
  <link slot="head" rel="stylesheet" href="/css/em-kontakty.css" />

  <div class="em-hero">
    <div class="em-hero-inner">
      <h1>Контакты</h1>
      <p class="em-hero-sub">Свяжитесь удобным способом — отвечаем в течение 1–2 рабочих дней</p>
    </div>
  </div>

  <div class="em-section-alt" id="kontakty-blok">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Свяжитесь с нами</span>
      <h2>Как с нами связаться</h2>

      <a href={`tel:${PHONE}`} class="em-kontakty-phone">
        <svg class="em-kontakty-phone-icon" viewBox="0 0 24 24">
          <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"/>
        </svg>
        {PHONE_DISPLAY}
      </a>

      <div class="em-kontakty-info-grid">
        <div class="em-kontakty-info-card">
          <div class="em-kontakty-info-label">Email</div>
          <a href={`mailto:${EMAIL}`} class="em-kontakty-info-value">{EMAIL}</a>
        </div>
        <div class="em-kontakty-info-card">
          <div class="em-kontakty-info-label">Адрес</div>
          <span class="em-kontakty-info-value">{ADDRESS}</span>
        </div>
        <div class="em-kontakty-info-card">
          <div class="em-kontakty-info-label">Мессенджеры</div>
          <span class="em-kontakty-info-value">Viber · Telegram · WhatsApp — по тому же номеру</span>
        </div>
      </div>

      <p class="em-kontakty-hint">Нажмите на иконку, чтобы позвонить или открыть удобный мессенджер:</p>

      <div class="em-contact-grid">
        <a href={`tel:${PHONE}`} class="em-contact-card">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"/></svg>
          <span class="em-contact-card-label">Позвонить</span>
        </a>
        <a href={`mailto:${EMAIL}`} class="em-contact-card">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M2 4h20v16H2V4zm2 2v.01L12 13l8-6.99V6H4zm16 2.24l-7.39 6.47a1 1 0 0 1-1.22 0L4 8.24V18h16V8.24z"/></svg>
          <span class="em-contact-card-label">Написать email</span>
        </a>
        <a href={VIBER} class="em-contact-card em-contact-card-viber">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2C6.5 2 2.4 5.6 2.4 10.4c0 2.6 1.3 4.9 3.4 6.5l-.5 3.7a.6.6 0 0 0 .9.6l3.6-2.1c.7.1 1.4.2 2.2.2 5.5 0 9.6-3.6 9.6-8.4S17.5 2 12 2z"/></svg>
          <span class="em-contact-card-label">Viber</span>
        </a>
        <a href={TELEGRAM} class="em-contact-card em-contact-card-telegram">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M21.5 4.5L2.7 12c-.8.3-.8 1.5.1 1.7l4.6 1.4 1.8 5.5c.3.8 1.3.9 1.8.2l2.6-3.3 4.9 3.6c.7.5 1.7.1 1.9-.7l3-15c.2-.9-.7-1.7-1.6-1.4z"/></svg>
          <span class="em-contact-card-label">Telegram</span>
        </a>
        <a href={WHATSAPP} class="em-contact-card em-contact-card-whatsapp">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2a10 10 0 0 0-8.6 15L2 22l5.2-1.4A10 10 0 1 0 12 2zm5.6 14.3c-.2.7-1.4 1.3-1.9 1.4-.5.1-1.1.1-1.8-.1-.4-.1-1-.3-1.7-.6-3-1.3-4.9-4.3-5.1-4.5-.1-.2-1.2-1.6-1.2-3s.7-2.1 1-2.4c.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5.2.5.7 1.7.8 1.8.1.2.1.3 0 .5-.1.2-.2.3-.3.5l-.5.5c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.5 1.5.3.1.5.1.6-.1l.7-.8c.2-.3.4-.2.7-.1l1.6.8c.2.1.4.2.4.4.1.2.1.7-.1 1.1z"/></svg>
          <span class="em-contact-card-label">WhatsApp</span>
        </a>
        <a href={MAPS_URL} target="_blank" rel="noopener" class="em-contact-card">
          <svg class="em-contact-card-icon" viewBox="0 0 24 24"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7zm0 9.5A2.5 2.5 0 1 1 12 6.5a2.5 2.5 0 0 1 0 5z"/></svg>
          <span class="em-contact-card-label">Открыть на карте</span>
        </a>
      </div>

      <div class="em-kontakty-schedule">
        <div class="em-kontakty-schedule-title">График работы</div>
        <div class="em-kontakty-schedule-grid">
          <div class="em-schedule-row em-schedule-row--work"><span class="em-schedule-day">Понедельник</span><span class="em-schedule-time">9:00 – 17:00</span></div>
          <div class="em-schedule-row em-schedule-row--work"><span class="em-schedule-day">Вторник</span><span class="em-schedule-time">9:00 – 17:00</span></div>
          <div class="em-schedule-row em-schedule-row--work"><span class="em-schedule-day">Среда</span><span class="em-schedule-time">9:00 – 17:00</span></div>
          <div class="em-schedule-row em-schedule-row--work"><span class="em-schedule-day">Четверг</span><span class="em-schedule-time">9:00 – 17:00</span></div>
          <div class="em-schedule-row em-schedule-row--work"><span class="em-schedule-day">Пятница</span><span class="em-schedule-time">9:00 – 17:00</span></div>
          <div class="em-schedule-row em-schedule-row--off"><span class="em-schedule-day">Суббота</span><span class="em-schedule-time em-schedule-off">выходной</span></div>
          <div class="em-schedule-row em-schedule-row--off"><span class="em-schedule-day">Воскресенье</span><span class="em-schedule-time em-schedule-off">выходной</span></div>
        </div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <span class="em-section-label">Адрес</span>
    <h2>Как нас найти</h2>
    <p class="em-lead">{ADDRESS}</p>
    <div class="em-kontakty-map-wrap">
      <iframe
        src={`https://maps.google.com/maps?q=${encodeURIComponent(ADDRESS)}&output=embed&z=16`}
        width="100%" height="420"
        style="border:0; border-radius: 12px; display: block;"
        allowfullscreen loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Расположение на карте — ${ADDRESS}`}
      ></iframe>
    </div>
    <div class="em-kontakty-map-cta">
      <a href={MAPS_URL} target="_blank" rel="noopener" class="em-btn-primary">Открыть в Google Maps →</a>
    </div>
  </section>

  <script is:inline src="/js/em-site.js"></script>
</BaseLayout>
