---
import { SITE_CANONICAL } from '../../../config';
import ProductLayout from '../../../layouts/ProductLayout.astro';

const page = {
  lang:        'ru' as const,
  altUrl:      '/posluhy-ta-produktsiia/plk/',
  section:     'posluhy',
  title:       'Программирование ПЛК на заказ — Киев и область | elektroschit.com.ua',
  description: 'Программирование логических контроллеров под ваше техническое задание. Управление двигателями, насосами, вентиляцией, технологическими процессами. Отдельно или вместе со сборкой щита. Киев и вся Украина.',
  canonical:   `${SITE_CANONICAL}/ru/posluhy-ta-produktsiia/plk/`,
  crumbs: [
    { label: 'Главная',  href: '/ru/' },
    { label: 'Услуги',  href: '/ru/posluhy-ta-produktsiia/' },
    { label: 'Программирование ПЛК' },
  ],
};

const hero = {
  tag:    'Услуга · Киев и область',
  h1:     'Программирование ПЛК на заказ',
  lead:   'Разрабатываем программы для логических контроллеров под конкретное техническое задание. Управление двигателями, насосами, вентиляцией, технологическими процессами — от простой последовательности пуска до алгоритмов управления несколькими узлами. Отдельно или вместе со сборкой щита. Киев, Киевская область и вся Украина.',
  badges: [
    '<strong>ПЛК + щит</strong> или только программа',
    '<strong>от 1 недели</strong> — разработка',
    '<strong>12 мес.</strong> — гарантия',
    '<strong>25 лет</strong> — опыт',
  ],
  collage: [
    { src: '/images/plk/plk-oven-flexi-s2-a1-releini-moduli-kyiv-2026-06-c1.jpg',  alt: 'Щит управления с ПЛК ОВЕН Flexi S2-A1 и реле ETI — общий вид монтажа' },
    { src: '/images/plk/plk-schneider-zelio-sr3-krupno-kyiv-2026-06-c2.jpg',       alt: 'Контроллер Schneider Electric Zelio SR3 B261BD — монтаж на DIN-рейке' },
    { src: '/images/plk/plk-oven-pr100-schebt-releini-moduli-kyiv-2026-06-c3.jpg', alt: 'ПЛК ОВЕН ПР100 с соединительным блоком ETI и группой реле — щит управления' },
    { src: '/images/plk/plk-aqteck-pr200-schyt-compact-kyiv-2026-06-c4.jpg',       alt: 'Щит управления с ПЛК AQteck ПР200 — компактное исполнение, питание Mean Well' },
  ],
};

const gallery = {
  h2: 'Щиты с ПЛК — фото с нашего производства',
  items: [
    { src: '/images/plk/plk-schyt-oven-velykyi-releini-blok-kyiv-2026-06-01.jpg',      alt: 'Большой щит управления с ПЛК ОВЕН и блоком реле',                      caption: 'Большой щит управления с ПЛК ОВЕН и блоком реле — общий вид открытого щита', large: true },
    { src: '/images/plk/plk-eaton-easy-schyt-keruvannia-kyiv-2026-06-02.jpg',           alt: 'Щит управления с контроллером Eaton Easy — автоматы ETI, плавные пускатели WEG SSW-07', caption: 'Щит с Eaton Easy и плавными пускателями WEG SSW-07 — управление группой двигателей' },
    { src: '/images/plk/plk-oven-flexi-s2-a1-krupno-kyiv-2026-06-03.jpg',              alt: 'ПЛК ОВЕН Flexi S2-A1 крупным планом — подключённые входы выходы, маркировка', caption: 'ОВЕН Flexi S2-A1 крупным планом — подключённые клеммы, маркировка входов и выходов' },
    { src: '/images/plk/plk-oven-pr100-robota-indykatory-kyiv-2026-06-04.jpg',          alt: 'ПЛК ОВЕН ПР100 крупно — индикаторы DI AI DO в режиме работы',           caption: 'ОВЕН ПР100 — индикаторы состояния DI, AI, DO в режиме работы программы' },
    { src: '/images/plk/plk-schneider-zelio-schyt-krupno-kyiv-2026-06-05.jpg',         alt: 'Schneider Electric Zelio Logic в щите — реле ETI, клеммы, маркировка',   caption: 'Schneider Electric Zelio Logic в щите: реле ETI, аккуратная маркировка клемм' },
    { src: '/images/plk/plk-schyt-zelio-kontaktory-lytseva-kyiv-2026-06-06.jpg',       alt: 'Щит управления с Zelio и контакторами ETI — лицевая панель с индикацией', caption: 'Щит с Zelio и контакторами ETI — четыре ряда DIN-реек, аккуратный монтаж' },
    { src: '/images/plk/plk-litseva-panel-shchyt-shuhnk-kyiv-2026-06-07.jpg',          alt: 'Лицевая панель щита управления — кнопки пуска/останова с подписями программ', caption: 'Лицевая панель щита ШУНК с подписанными кнопками — ручной и автоматический режимы' },
    { src: '/images/plk/plk-schyt-m-puskateli-soft-starter-kyiv-2026-06-08.jpg',       alt: 'Щит управления двигателями — четыре плавных пускателя WEG и автоматы ETI', caption: 'Щит с четырьмя плавными пускателями WEG SSW-07 и автоматами ETI — управление двигателями' },
  ],
};

const objects = {
  label: 'Направления',
  h2:    'Что программируем',
  lead:  'Берёмся за задачи малой и средней сложности: автоматизация отдельного процесса, цеха, небольшой производственной линии. Не автоматизируем крупные заводские комплексы — работаем там, где нужно точное и надёжное решение под конкретную задачу.',
  cards: [
    { num: '01', title: 'Управление электродвигателями', text: 'Прямой пуск, реверс, звезда-треугольник, поочерёдные запуски по сценарию.' },
    { num: '02', title: 'Насосные станции',              text: 'Управление по уровню или давлению, очерёдность насосов, защиты.' },
    { num: '03', title: 'Вентиляция и климатика',        text: 'Пуск/останов по датчику, блокировки, аварийная сигнализация.' },
    { num: '04', title: 'Противопожарная автоматика',    text: 'Дымоудаление, подпор воздуха, управление клапанами и приводами.' },
    { num: '05', title: 'Технологические процессы',      text: 'Управление клапанами, двигателями и исполнительными механизмами по заданному сценарию.' },
    { num: '06', title: 'Агропроизводство',              text: 'Автоматизация вентиляции, кормления, полива на фермах и тепличных хозяйствах.' },
  ],
};

const specs = {
  h2:   'С какими контроллерами работаем',
  rows: [
    { label: 'Siemens LOGO!',                  value: 'Компактные задачи: управление 1–3 узлами, простые алгоритмы, таймеры, счётчики' },
    { label: 'Schneider Electric Zelio Logic', value: 'Аналог LOGO! — применяем в зависимости от наличия и пожеланий заказчика' },
    { label: 'Eaton Easy (Easy-E4)',           value: 'Компактные решения для небольших установок' },
    { label: 'ОВЕН',                           value: 'Украинский производитель, широко применяется на украинских предприятиях' },
  ],
};

const steps = {
  h2:    '5 шагов от ТЗ до готового решения',
  items: [
    { title: 'Техническое задание',       text: 'Присылаете описание задачи или схему. Принимаем PDF, DWG, фото, устное описание — любой удобный формат.' },
    { title: 'Разработка алгоритма',      text: 'Разрабатываем или проверяем алгоритм работы, согласовываем стоимость и сроки. Отвечаем за 1–2 дня.' },
    { title: 'Оплата',                    text: 'После оплаты изделие или услуга ставится в исполнение.' },
    { title: 'Сборка и программирование', text: 'Собираем щит, устанавливаем контроллер, пишем и загружаем программу.' },
    { title: 'Тестирование и передача',   text: 'Проверяем работу программы перед передачей. Паспорт изделия и схема — в щите.' },
  ],
};

const why = {
  h2:    'Почему заказывают у нас',
  cards: [
    { title: 'Опыт с 1999 года',                   text: '25+ лет изготовления щитов и программирования контроллеров для промышленных и коммерческих объектов.' },
    { title: 'Разрабатываем алгоритм по описанию',  text: 'Не нужна готовая схема — опишите задачу словами, мы разработаем алгоритм и согласуем с вами перед началом.' },
    { title: 'Работа по проектной документации',    text: 'Принимаем схемы от любой проектной организации и программируем точно по ним.' },
    { title: 'Тестирование перед отправкой',        text: 'Каждая программа проверяется до передачи заказчику. Паспорт изделия — с каждым щитом.' },
    { title: 'Доставка по всей Украине',            text: 'По Киеву и Киевской обл. — собственным транспортом. По Украине — Новой Почтой.' },
    { title: 'Гарантия 12 месяцев',                text: 'На каждый изготовленный щит и разработанную программу — письменное гарантийное обязательство.' },
  ],
};

const faq = {
  sectionTitle: 'Вопросы о программировании ПЛК',
  items: [
    { q: 'Что делать, если готовой схемы нет?',               a: 'Пришлите описание задачи — какие потребители, какая нагрузка, какие режимы работы. Разработаем принципиальную схему самостоятельно и согласуем с вами перед началом изготовления.' },
    { q: 'Можно ли заказать только программу без щита?',       a: 'Да. Если контроллер уже установлен или щит собирает другая организация — разрабатываем и загружаем программу отдельно. Для этого нужны паспортные данные контроллера и техническое задание на алгоритм работы.' },
    { q: 'Какие задачи вы берётесь автоматизировать?',         a: 'Берёмся за задачи малой и средней сложности — автоматизация отдельного процесса, цеха или небольшой производственной линии. Например: управление группой двигателей и клапанов по заданному сценарию, автоматизация насосной станции, вентиляции или противопожарной системы.' },
    { q: 'Как описать задачу, если я не знаю что мне нужно?',  a: 'Опишите что должна делать система — словами, без технических деталей. Что включается, что выключается, при каком условии, что должно произойти в аварийной ситуации. Этого достаточно, чтобы мы могли оценить задачу и предложить решение.' },
    { q: 'Нужен ли ПЛК или достаточно релейной схемы?',        a: 'Зависит от задачи. Если сигналов и узлов немного — реализуем на релейно-контакторной схеме: это надёжно и дешевле. Если логика сложная или узлов много — интегрируем ПЛК и разрабатываем программу под задачу.' },
    { q: 'Какую документацию вы передаёте вместе со щитом?',   a: 'Паспорт изделия и принципиальную схему. Документы вкладываются непосредственно в щит.' },
    { q: 'Можно ли предоставить свои компоненты для сборки?',  a: 'Нет. Мы самостоятельно закупаем всё оборудование согласно согласованной спецификации и передаём заказчику готовое изделие с гарантией. Это позволяет нам отвечать за качество щита от начала до конца.' },
  ],
};
---
<ProductLayout
  {page}
  slug="plk"
  {hero}
  {gallery}
  {objects}
  {specs}
  {steps}
  {why}
  {faq}
  contactTitle="Готовы обсудить ваш заказ — программирование ПЛК"
>
  <!-- extra1: Контроллеры — белый фон -->
  <section slot="extra1" class="em-section">
    <span class="em-section-label">Контроллеры</span>
    <h2>С какими контроллерами работаем</h2>
    <table class="em-specs-table">
      <tbody>
        <tr><td class="em-specs-label">Siemens LOGO!</td><td class="em-specs-value">Компактные задачи: управление 1–3 узлами, простые алгоритмы, таймеры, счётчики</td></tr>
        <tr><td class="em-specs-label">Schneider Electric Zelio Logic</td><td class="em-specs-value">Аналог LOGO! — применяем в зависимости от наличия и пожеланий заказчика</td></tr>
        <tr><td class="em-specs-label">Eaton Easy (Easy-E4)</td><td class="em-specs-value">Компактные решения для небольших установок</td></tr>
        <tr><td class="em-specs-label">ОВЕН</td><td class="em-specs-value">Украинский производитель, широко применяется на украинских предприятиях</td></tr>
      </tbody>
    </table>
    <p style="margin-top:16px; color:var(--c-muted); font-family:var(--ff-body); font-size:14px;">Если у вас другой контроллер — уточните при подаче ТЗ, рассмотрим индивидуально.</p>
  </section>

  <!-- extra2: Форматы работы — зелёный фон -->
  <div slot="extra2" class="em-section-alt">
    <div class="em-section-alt-inner">
      <span class="em-section-label">Форматы работы</span>
      <h2>Отдельно или вместе со щитом</h2>
      <div class="em-why-grid">
        <div class="em-why-card">
          <div class="em-why-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
            </svg>
          </div>
          <h3>Щит + программа под ключ</h3>
          <p>Собираем щит управления с установленным контроллером и разрабатываем программу под ваше техническое задание. Тестируем всё вместе перед передачей. Одна ответственная сторона от начала до конца.</p>
        </div>
        <div class="em-why-card">
          <div class="em-why-card-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <path d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
            </svg>
          </div>
          <h3>Только программа</h3>
          <p>Если щит уже есть или его собирает другая организация — разрабатываем и загружаем программу отдельно. Нужны паспортные данные контроллера и техническое задание на алгоритм работы.</p>
        </div>
      </div>
    </div>
  </div>
</ProductLayout>
