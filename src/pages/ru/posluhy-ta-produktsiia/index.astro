---
import { SITE_CANONICAL } from '../../../config';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactBlock from '../../../components/ContactBlock.astro';

const page = {
  lang:        'ru' as const,
  altUrl:      '/posluhy-ta-produktsiia/',
  section:     'produktsiia',
  title:       'Продукция и услуги — изготовление электрощитов | elektroschit.com.ua',
  description: 'Изготовление силовых щитов, щитов управления, КРМ, дымоудаления. Программирование ПЛК, электромонтажные работы. Гарантия 12 месяцев. Киев и вся Украина.',
  canonical:   `${SITE_CANONICAL}/ru/posluhy-ta-produktsiia/`,
  crumbs: [
    { label: 'Главная', href: '/ru/' },
    { label: 'Продукция и услуги' },
  ],
};
---
<BaseLayout {page}>
  <link slot="head" rel="stylesheet" href="/css/em-hrshch.css" />
  <style slot="head">
    .em-hub-hero { background: var(--c-bg2); border-bottom: 2px solid var(--c-accent-border); padding: 56px 24px 48px; }
    .em-hub-hero-inner { max-width: 1200px; margin: 0 auto; }
    .em-hub-hero-inner h1 { margin: 10px 0 14px; }
    .em-hub-hero-lead { font-family: var(--ff-body); font-size: 17px; color: var(--c-muted); max-width: 620px; line-height: 1.65; margin: 0; }
    .em-hub-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
    .em-hub-section-title { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
    .em-hub-section-title h2 { font-family: var(--ff); font-size: clamp(18px, 2vw, 22px); font-weight: 700; color: var(--c-head); margin: 0; white-space: nowrap; }
    .em-hub-title-line { flex: 1; height: 1px; background: var(--c-divider); }
    .em-hub-title-count { font-family: var(--ff-body); font-size: 11px; font-weight: 700; color: var(--c-muted); text-transform: uppercase; letter-spacing: .08em; white-space: nowrap; }
    .em-hub-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 48px; align-items: stretch; }
    .em-hub-grid-services { grid-template-columns: repeat(3, 1fr); margin-bottom: 0; }
    .em-hub-card { display: flex; flex-direction: column; padding: 24px 20px 20px; background: #fff; border: 1.5px solid var(--c-accent-border); border-radius: var(--radius); text-decoration: none; color: inherit; transition: border-color .2s, box-shadow .2s, transform .2s; position: relative; overflow: hidden; }
    .em-hub-card::before { content: ''; position: absolute; top: 0; left: 0; width: 3px; height: 100%; background: var(--c-accent); opacity: 0; transition: opacity .2s; }
    .em-hub-card:hover { border-color: var(--c-accent); box-shadow: var(--shadow-card); transform: translateY(-3px); }
    .em-hub-card:hover::before { opacity: 1; }
    .em-hub-card-icon { width: 48px; height: 48px; border-radius: var(--radius-sm); background: var(--c-accent-faint); border: 1px solid var(--c-accent-border); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; flex-shrink: 0; transition: background .2s; }
    .em-hub-card:hover .em-hub-card-icon { background: var(--c-accent-mid); }
    .em-hub-card-icon svg { width: 24px; height: 24px; fill: var(--c-accent); }
    .em-hub-card-body { flex: 1; display: flex; flex-direction: column; }
    .em-hub-card-body h3 { font-family: var(--ff); font-size: 14px; font-weight: 700; color: var(--c-head); margin: 0 0 8px; line-height: 1.35; }
    .em-hub-card-body p { font-family: var(--ff-body); font-size: 12.5px; color: var(--c-muted); line-height: 1.55; margin: 0 0 16px; flex: 1; }
    .em-hub-card-link { display: inline-flex; align-items: center; gap: 4px; font-family: var(--ff-body); font-size: 12.5px; font-weight: 700; color: var(--c-accent); margin-top: auto; transition: gap .15s; }
    .em-hub-card:hover .em-hub-card-link { gap: 8px; }
    .em-hub-card-link svg { width: 14px; height: 14px; fill: currentColor; flex-shrink: 0; }
    @media (min-width: 901px) and (max-width: 1100px) { .em-hub-grid { grid-template-columns: repeat(3, 1fr) !important; } }
    @media (min-width: 601px) and (max-width: 900px) { .em-hub-grid { grid-template-columns: repeat(2, 1fr) !important; } .em-hub-grid-services { grid-template-columns: repeat(2, 1fr) !important; } .em-hub-hero { padding: 40px 16px 36px !important; } }
    @media (max-width: 600px) { .em-hub-grid { grid-template-columns: 1fr !important; } .em-hub-grid-services { grid-template-columns: 1fr !important; } .em-hub-hero { padding: 36px 16px 32px !important; } .em-hub-badges { display: none !important; } }
  </style>

  <div class="em-hub-hero">
    <div class="em-hub-hero-inner">
      <span class="em-section-label">Производство · Киев и область</span>
      <h1>Продукция и услуги</h1>
      <p class="em-hub-hero-lead">Изготавливаем силовые щиты и щиты управления любой сложности. Работаем по вашим схемам или разрабатываем с нуля. Гарантия 12 месяцев, сроки от 2 недель.</p>
      <div class="em-hub-badges">
        <div class="em-badge"><strong>25 лет</strong> — опыт</div>
        <div class="em-badge"><strong>от 2 недель</strong> — сроки</div>
        <div class="em-badge"><strong>12 мес.</strong> — гарантия</div>
        <div class="em-badge"><strong>ETI · Hager · Schneider · Eaton</strong></div>
      </div>
    </div>
  </div>

  <section class="em-section">
    <div class="em-hub-section-title">
      <h2>Продукция</h2>
      <div class="em-hub-title-line"></div>
      <span class="em-hub-title-count">7 видов щитов</span>
    </div>
    <div class="em-hub-grid">
      <a href="/ru/posluhy-ta-produktsiia/hrshch/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M4 4h4v4H4zm6 0h4v4h-4zm6 0h4v4h-4zM4 10h16v2H4zm0 4h4v6H4zm6 0h10v6H10z"/></svg></div>
        <div class="em-hub-card-body"><h3>ГРЩ / ВРЩ — силовые щиты</h3><p>Главные и вводно-распределительные щиты до 630А. Одно- и многовводные, по проекту или ТЗ.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/dymovydalennia/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M19 9c0-3.87-3.13-7-7-7S5 5.13 5 9c0 2.93 1.81 5.46 4.37 6.53L8 22h8l-1.38-6.47C17.19 14.46 19 11.93 19 9zm-7-5c2.76 0 5 2.24 5 5s-2.24 5-5 5-5-2.24-5-5 2.24-5 5-5z"/></svg></div>
        <div class="em-hub-card-body"><h3>Щиты дымоудаления</h3><p>Дымоудаление, подпор воздуха, управление противопожарными клапанами. Зональное управление, от АУПС.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/dvyhuny/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm0 4a6 6 0 110 12A6 6 0 0112 6zm0 2a4 4 0 100 8 4 4 0 000-8z"/></svg></div>
        <div class="em-hub-card-body"><h3>Щиты управления двигателями</h3><p>Прямой пуск, реверс, звезда-треугольник, софтстартер, частотный преобразователь. От 1 до 12+ двигателей.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/shuz/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M3 12h2v3H3zm4-3h2v6H7zm4-4h2v10h-2zm4 2h2v8h-2zm4 3h2v5h-2z"/></svg></div>
        <div class="em-hub-card-body"><h3>Щиты управления задвижками (ШУЗ)</h3><p>Управление электроприводными задвижками. Местный, дистанционный, автоматический режимы. От 1 до 32+ приводов.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/krm/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M7 2v11h3v9l7-12h-4l4-8z"/></svg></div>
        <div class="em-hub-card-body"><h3>КРМ — конденсаторные установки</h3><p>Компенсация реактивной мощности. Автоматический регулятор cos φ ≥ 0,95. Расчёт по вашим данным.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/zenitni-lihtari/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M12 7a5 5 0 100 10A5 5 0 0012 7zM2 13h2a8.001 8.001 0 000-2H2v2zm18 0h2v-2h-2a8 8 0 010 2zM11 2v2a8 8 0 012 0V2h-2zm0 18v2h2v-2a8.001 8.001 0 01-2 0z"/></svg></div>
        <div class="em-hub-card-body"><h3>Щиты управления зенитными фонарями</h3><p>Фрамуги, люки, противопожарное открытие от АУПС. Зональное управление, проветривание по расписанию.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/ahro/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M12 3L2 12h3v8h6v-5h2v5h6v-8h3L12 3z"/></svg></div>
        <div class="em-hub-card-body"><h3>Электрощиты для агрохозяйств</h3><p>Вентиляция, аэрация, кормовые системы. Коровники, свинарники, зернохранилища, тепличные хозяйства.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
    </div>

    <div class="em-hub-section-title">
      <h2>Услуги</h2>
      <div class="em-hub-title-line"></div>
      <span class="em-hub-title-count">2 услуги</span>
    </div>
    <div class="em-hub-grid em-hub-grid-services">
      <a href="/ru/posluhy-ta-produktsiia/plk/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M20 3H4a1 1 0 00-1 1v16a1 1 0 001 1h16a1 1 0 001-1V4a1 1 0 00-1-1zm-1 16H5V5h14v14zM7 7h2v2H7zm4 0h6v2h-6zm-4 4h2v2H7zm4 0h6v2h-6zm-4 4h2v2H7zm4 0h6v2h-6z"/></svg></div>
        <div class="em-hub-card-body"><h3>Программирование ПЛК</h3><p>Разработка программ для Siemens LOGO!, Schneider Zelio, Eaton Easy, ОВЕН и других. Отдельно или вместе со сборкой щита. Любая логика управления под ваше ТЗ.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
      <a href="/ru/posluhy-ta-produktsiia/elektromontazh/" class="em-hub-card">
        <div class="em-hub-card-icon"><svg viewBox="0 0 24 24"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg></div>
        <div class="em-hub-card-body"><h3>Электромонтажные работы</h3><p>Прокладка кабельных трасс, монтаж и подключение щитов, подключение технологического оборудования, пусконаладка. Промышленные объекты, склады, агропредприятия.</p><span class="em-hub-card-link">Подробнее <svg viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg></span></div>
      </a>
    </div>
  </section>

  <ContactBlock title="Готовы обсудить ваш заказ" lang="ru" />
  <script is:inline src="/js/em-site.js"></script>
</BaseLayout>
