---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactBlock from '../../components/ContactBlock.astro';
import AlsoMake from '../../components/AlsoMake.astro';
import Lightbox from '../../components/Lightbox.astro';
import WorkPhotos from '../../components/WorkPhotos.astro';
import WorkDescription from '../../components/WorkDescription.astro';
import WorkSpecs from '../../components/WorkSpecs.astro';
import WorkBrands from '../../components/WorkBrands.astro';
import WorkSimilar from '../../components/WorkSimilar.astro';
import { SITE_CANONICAL } from '../../config';

export async function getStaticPaths() {
  const works = await getCollection('vykonani-roboty');
  return works.map(work => ({
    params: { slug: work.slug },
    props:  { work },
  }));
}

const { work } = Astro.props;
const { data }  = work;
const { Content } = await render(work);

const seoTitle = data.seoTitle ?? `${data.title} — Виконані роботи | elektroschit.com.ua`;
const canonical = `${SITE_CANONICAL}/vykonani-roboty/${work.slug}/`;

const page = {
  section:  'vykonani-roboty',
  title:    seoTitle,
  description: data.description,
  canonical,
  lang:     'uk' as const,
  altUrl:   '/ru/vykonani-roboty/',
  ogType:   'article' as const,
  crumbs: [
    { label: 'Головна',          href: '/' },
    { label: 'Виконані роботи',  href: '/vykonani-roboty/' },
    { label: data.title },
  ],
};
---
<BaseLayout {page}>
  <link slot="head" rel="stylesheet" href="/css/em-hrshch.css" />
  <link slot="head" rel="stylesheet" href="/css/em-work.css" />

  <WorkPhotos photos={data.photos} title={data.title} />

  <WorkDescription
    title={data.title}
    types={data.types}
    tags={data.tags}
    properties={data.properties}
  >
    <Content />
  </WorkDescription>

  <WorkSpecs specs={data.specs} />
  <WorkBrands brands={data.brands} />

  <WorkSimilar
    currentSlug={work.slug}
    types={data.types}
    tags={data.tags}
  />

  <ContactBlock title="Хочете такий щит? Зв'яжіться з нами" />
  <AlsoMake currentSlug="" />
  <Lightbox />

  <script is:inline src="/js/em-site.js"></script>
  <script is:inline src="/js/em-work-lightbox.js"></script>
</BaseLayout>
